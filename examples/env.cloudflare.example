# NanoBK Proxy Suite — Cloudflare Admin Environment
#
# Copy this file to /root/.nanok-cf-admin.env on your VPS.
# chmod 600 /root/.nanok-cf-admin.env
#
# These values are used by rotate-keys.sh to sync the profile
# to Cloudflare Workers via the admin API.
#
# Do NOT commit this file with real values.

# ── Admin Token ─────────────────────────────────────────────────────────────
# The ADMIN_TOKEN secret you set on the nanok Worker.
# Must match exactly (no trailing newline).
ADMIN_TOKEN="REPLACE_WITH_YOUR_ADMIN_TOKEN"

# ── Admin API URLs ──────────────────────────────────────────────────────────
# Your nanok Worker's admin endpoints.
# Replace YOUR_WORKER_HOST with your actual Worker custom domain.
ADMIN_CURRENT_URL="https://YOUR_WORKER_HOST/admin/current"
ADMIN_UPDATE_URL="https://YOUR_WORKER_HOST/admin/update"

# ── Subscription URL (for reference) ────────────────────────────────────────
# Not used by rotate-keys.sh, but useful for documentation.
# SUB_URL="https://YOUR_WORKER_HOST/jb?token=YOUR_SUB_TOKEN"
