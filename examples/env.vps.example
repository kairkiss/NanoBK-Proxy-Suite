# NanoBK Proxy Suite — VPS Environment Variables
#
# Copy this file to /etc/nanobk/config.env and replace all placeholders.
# chmod 600 /etc/nanobk/config.env
#
# Do NOT commit this file with real values.

# ── VPS Identity ────────────────────────────────────────────────────────────
# Your VPS public IP address
VPS_IP="REPLACE_WITH_VPS_IP"

# Domain names (must point to VPS_IP via DNS)
HY2_DOMAIN="hy2.example.com"
TUIC_DOMAIN="tuic.example.com"
TROJAN_DOMAIN="trojan.example.com"
REALITY_DOMAIN="REPLACE_WITH_VPS_IP"

# ── Port Configuration ──────────────────────────────────────────────────────
HY2_PORT=443
TUIC_PORT=9443
REALITY_PORT=8443
TROJAN_PORT=2443

# ── TLS Certificates ────────────────────────────────────────────────────────
# Paths to TLS certificate and key files
HY2_CERT="/etc/hysteria/cert.pem"
HY2_KEY="/etc/hysteria/key.pem"
TUIC_CERT="/etc/proxy-stack/tuic-v5-9443/cert.pem"
TUIC_KEY="/etc/proxy-stack/tuic-v5-9443/key.pem"
TROJAN_CERT="/etc/proxy-stack/xray-trojan-2443/cert.pem"
TROJAN_KEY="/etc/proxy-stack/xray-trojan-2443/key.pem"

# ── Reality Settings ────────────────────────────────────────────────────────
# The SNI server name for Reality (must be a real TLS site)
REALITY_SERVERNAME="www.example.com"
# The dest address for Reality handshake
REALITY_DEST="www.example.com:443"

# ── Service Paths ───────────────────────────────────────────────────────────
HY2_CONFIG="/etc/hysteria/config.yaml"
TUIC_CONFIG="/etc/proxy-stack/tuic-v5-9443/config.json"
REALITY_CONFIG="/etc/proxy-stack/xray-reality-8443/config.json"
TROJAN_CONFIG="/etc/proxy-stack/xray-trojan-2443/config.json"

# ── Systemd Services ────────────────────────────────────────────────────────
HY2_SERVICE="hysteria-server.service"
TUIC_SERVICE="tuic-v5-9443.service"
REALITY_SERVICE="xray-reality-8443.service"
TROJAN_SERVICE="xray-trojan-2443.service"

# ── Display Names (for subscription profile) ────────────────────────────────
HY2_NAME="JP-TYO-01 | HY2 | 443 | Primary"
TUIC_NAME="JP-TYO-02 | TUIC V5 | 9443 | Speed"
REALITY_NAME="JP-TYO-03 | Reality | 8443 | Stealth"
TROJAN_NAME="JP-TYO-04 | Trojan | 2443 | Fallback"
POETRY_NODE_NAME="Status placeholder"
RECOMMEND_NODE_NAME="Project placeholder"
