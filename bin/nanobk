#!/usr/bin/env bash
# NanoBK Proxy Suite — Unified CLI
#
# Stable command-line interface for NanoBK management.
# Designed for use by future Telegram Bot / Web Panel (1.x).
#
# Usage:
#   nanobk status
#   nanobk doctor
#   nanobk install --mode commands
#   nanobk cf deploy --dry-run
#   nanobk rotate all --skip-cloudflare
#   nanobk test
#   nanobk install-cli
#   nanobk version

set -Eeuo pipefail

# ── Version ─────────────────────────────────────────────────────────────────

NANOBK_VERSION="1.8.22"

# ── Colors ──────────────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

log()   { echo -e "${BLUE}[INFO]${NC}  $*"; }
ok()    { echo -e "${GREEN}[OK]${NC}    $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; }
err()   { echo -e "${RED}[ERROR]${NC} $*" >&2; }
die()   { err "$*"; exit 1; }

# ── Global flags ────────────────────────────────────────────────────────────

DRY_RUN=0
JSON_OUT=0
REPO_DIR=""
CONFIG_DIR="/etc/nanobk"

# ── JSON helpers ────────────────────────────────────────────────────────────

json_escape() {
  local input="$1"
  if command -v python3 &>/dev/null; then
    printf '%s' "$input" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()), end="")'
  else
    local result="$input"
    result="${result//\\/\\\\}"
    result="${result//\"/\\\"}"
    result="${result//$'\t'/\\t}"
    result="${result//$'\n'/\\n}"
    result="${result//$'\r'/\\r}"
    printf '"%s"' "$result"
  fi
}

# ── Fingerprint helper ──────────────────────────────────────────────────────

fingerprint_secret() {
  local value="$1"
  if [[ -z "$value" ]]; then
    echo ""
    return
  fi
  if command -v sha256sum &>/dev/null; then
    printf '%s' "$value" | sha256sum | awk '{print "sha256:" substr($1,1,8)}'
  elif command -v shasum &>/dev/null; then
    printf '%s' "$value" | LC_ALL=C LANG=C shasum -a 256 2>/dev/null | awk '{print "sha256:" substr($1,1,8)}'
  else
    echo "present"
  fi
}

# ── Safe env reader ─────────────────────────────────────────────────────────

# Read a single value from an env file without sourcing it.
# Does NOT execute shell commands in the file.
# Supports: KEY=value, KEY="value", KEY='value'
# Does NOT support: variable expansion ($OTHER), command substitution, multi-line.

read_env_value() {
  local file="$1"
  local key="$2"
  [[ -f "$file" ]] || return 0
  awk -v key="$key" '
    /^[[:space:]]*#/ { next }
    /^[[:space:]]*$/ { next }
    {
      line=$0
      sub(/^[[:space:]]*/, "", line)
      if (line ~ "^" key "=") {
        sub("^" key "=", "", line)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", line)
        # Strip surrounding quotes
        if ((substr(line,1,1) == "\"" && substr(line,length(line),1) == "\"") ||
            (substr(line,1,1) == "\x27" && substr(line,length(line),1) == "\x27")) {
          line=substr(line,2,length(line)-2)
        }
        print line
        exit
      }
    }
  ' "$file"
}

# ── Repo resolution ─────────────────────────────────────────────────────────

resolve_repo_dir() {
  if [[ -n "$REPO_DIR" ]]; then
    return
  fi

  if [[ -n "${NANOBK_REPO_DIR:-}" ]]; then
    REPO_DIR="$NANOBK_REPO_DIR"
    return
  fi

  local config_file="${CONFIG_DIR}/config.env"
  if [[ -f "$config_file" ]]; then
    local repo_from_config
    repo_from_config=$(grep -E '^NANOBK_REPO_DIR=' "$config_file" 2>/dev/null | head -1 | cut -d= -f2- | tr -d '"' || true)
    if [[ -n "$repo_from_config" ]] && [[ -d "$repo_from_config" ]]; then
      REPO_DIR="$repo_from_config"
      return
    fi
  fi

  for candidate in "/opt/NanoBK-Proxy-Suite" "${HOME}/NanoBK-Proxy-Suite"; do
    if [[ -d "$candidate" ]] && [[ -f "$candidate/installer/install.sh" ]]; then
      REPO_DIR="$candidate"
      return
    fi
  done

  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -f "${script_dir}/../installer/install.sh" ]]; then
    REPO_DIR="$(cd "${script_dir}/.." && pwd)"
    return
  fi

  die "无法定位 NanoBK 仓库。
请设置:
  export NANOBK_REPO_DIR=/path/to/NanoBK-Proxy-Suite
或重新运行 bootstrap:
  bash <(curl -fsSL https://raw.githubusercontent.com/kairkiss/NanoBK-Proxy-Suite/main/installer/bootstrap.sh)"
}

# ── Safe command runner ─────────────────────────────────────────────────────

print_cmd() {
  printf "  ${CYAN}\$${NC} "
  printf "%q " "$@"
  printf "\n"
}

run_script() {
  local desc="$1"
  shift
  local cmd=("$@")

  log "$desc"
  print_cmd "${cmd[@]}"

  if [[ "$DRY_RUN" == "1" ]]; then
    echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
    return 0
  fi

  "${cmd[@]}"
}

# ── Commands ────────────────────────────────────────────────────────────────

cmd_version() {
  echo "nanobk ${NANOBK_VERSION}"
}

cmd_help() {
  cat <<EOF
NanoBK Proxy Suite — Unified CLI v${NANOBK_VERSION}

用法: nanobk [全局选项] <命令> [命令选项...]

全局选项:
  --repo-dir PATH    指定仓库根目录
  --dry-run          只打印命令，不执行
  --json             JSON 输出（部分命令支持）
  --help             显示帮助
  --version          显示版本

命令:
  status [--config-dir PATH]  显示 VPS / Cloudflare / 聚合器状态
  doctor                      运行环境诊断
  install [args...]           启动交互式安装器
  install-cli                 安装 nanobk 到 /usr/local/bin
  cf deploy [args...]         部署 Cloudflare Workers
  cf verify [nanok|nanob]     刷新 Cloudflare 订阅验证状态
  cf install-admin-env        安装 rotate sync admin env 到 /root
  rotate <protocol> [args.]  换密钥: all|hy2|tuic|reality|trojan
  test [--all]                运行本地测试
  version                     显示版本

--dry-run 可以放在全局位置或命令后:
  nanobk --dry-run test
  nanobk test --dry-run

示例:
  nanobk status
  nanobk --json status
  nanobk doctor
  nanobk install-cli
  nanobk install --mode commands
  nanobk cf deploy --dry-run --create-kv --route-url https://nanok.example.com
  nanobk rotate all --skip-cloudflare
  nanobk test --all

CLI 安装:
  sudo nanobk install-cli
  # 或手动: sudo ln -sf "\$(pwd)/bin/nanobk" /usr/local/bin/nanobk
EOF
}

# ── install-cli ─────────────────────────────────────────────────────────────

cmd_install_cli() {
  local target="/usr/local/bin/nanobk"
  local force=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --target) target="$2"; shift ;;
      --force)  force=1 ;;
      --dry-run) DRY_RUN=1 ;;
      *) die "Unknown install-cli option: $1" ;;
    esac
    shift
  done

  local source_path="${REPO_DIR}/bin/nanobk"

  if [[ ! -f "$source_path" ]]; then
    die "Source not found: ${source_path}"
  fi

  # Check target existence (safe checks, no writes)
  if [[ -e "$target" ]] || [[ -L "$target" ]]; then
    if [[ -L "$target" ]]; then
      local current_link
      current_link=$(readlink "$target" 2>/dev/null || echo "")
      if [[ "$current_link" == "$source_path" ]]; then
        ok "nanobk 已安装: ${target} → ${source_path}"
        return 0
      fi
      # Different symlink
      if [[ "$force" != "1" ]]; then
        die "目标已存在，指向其他位置:
  ${target} → ${current_link}
  期望: ${source_path}
  使用 --force 覆盖。"
      fi
      warn "覆盖已有 symlink (--force): ${target} → ${current_link}"
    else
      # Regular file
      if [[ "$force" != "1" ]]; then
        die "目标已存在（非 symlink），不会覆盖:
  ${target}
  使用 --force 覆盖。"
      fi
      warn "覆盖已有文件 (--force): ${target}"
    fi
  fi

  # Dry-run: print what would happen, skip permission check
  if [[ "$DRY_RUN" == "1" ]]; then
    log "安装 nanobk CLI:"
    print_cmd ln -sf "$source_path" "$target"
    echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
    return 0
  fi

  # Check if target directory needs root
  local target_dir
  target_dir=$(dirname "$target")
  if [[ ! -w "$target_dir" ]] && [[ $EUID -ne 0 ]]; then
    echo ""
    warn "目标目录需要 root 权限: ${target_dir}"
    echo ""
    echo "  推荐命令:"
    echo "    sudo ln -sf \"${source_path}\" \"${target}\""
    echo ""
    die "请使用 sudo 重试。"
  fi

  log "安装 nanobk CLI:"
  print_cmd ln -sf "$source_path" "$target"

  ln -sf "$source_path" "$target"
  ok "已安装: ${target} → ${source_path}"
  echo ""
  echo "  现在可以直接使用: nanobk status"
}

# ── status ──────────────────────────────────────────────────────────────────

cmd_status() {
  local config_dir="$CONFIG_DIR"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --config-dir) config_dir="$2"; shift ;;
      --dry-run) ;;
      *) die "Unknown status option: $1" ;;
    esac
    shift
  done

  local config_file="${config_dir}/config.env"
  local profile_file="${config_dir}/profile.current.json"
  local secrets_file="${config_dir}/secrets.private.env"

  # Load VPS config
  local domain="" vps_ip="" geo="" reality_sname=""
  local hy2_service="hysteria-server.service"
  local tuic_service="tuic-v5-9443.service"
  local reality_service="xray-reality-8443.service"
  local trojan_service="xray-trojan-2443.service"

  local config_exists=0
  if [[ -f "$config_file" ]]; then
    config_exists=1
    # shellcheck source=/dev/null
    source "$config_file"
    domain="${NANOBK_DOMAIN:-}"
    vps_ip="${NANOBK_VPS_IP:-}"
    geo="${NANOBK_GEO_LABEL:-}"
    reality_sname="${REALITY_SERVERNAME:-}"
  fi

  # Check profile
  local profile_exists=0 profile_updated=""
  local has_hy2=0 has_tuic=0 has_reality=0 has_trojan=0

  if [[ -f "$profile_file" ]]; then
    profile_exists=1
    if command -v jq &>/dev/null; then
      profile_updated=$(jq -r '.updatedAt // empty' "$profile_file" 2>/dev/null || echo "")
      jq -e '.hy2' "$profile_file" >/dev/null 2>&1 && has_hy2=1
      jq -e '.tuic' "$profile_file" >/dev/null 2>&1 && has_tuic=1
      jq -e '.reality' "$profile_file" >/dev/null 2>&1 && has_reality=1
      jq -e '.trojan' "$profile_file" >/dev/null 2>&1 && has_trojan=1
    elif command -v python3 &>/dev/null; then
      profile_updated=$(python3 -c "import json; d=json.load(open('$profile_file')); print(d.get('updatedAt',''))" 2>/dev/null || echo "")
      python3 -c "import json; d=json.load(open('$profile_file')); [d[k] for k in ('hy2','tuic','reality','trojan')]" 2>/dev/null && {
        has_hy2=1; has_tuic=1; has_reality=1; has_trojan=1
      }
    fi
  fi

  # Check services
  local svc_hy2="unknown" svc_tuic="unknown" svc_reality="unknown" svc_trojan="unknown"
  if command -v systemctl &>/dev/null; then
    svc_hy2=$(systemctl is-active "$hy2_service" 2>/dev/null || echo "inactive")
    svc_tuic=$(systemctl is-active "$tuic_service" 2>/dev/null || echo "inactive")
    svc_reality=$(systemctl is-active "$reality_service" 2>/dev/null || echo "inactive")
    svc_trojan=$(systemctl is-active "$trojan_service" 2>/dev/null || echo "inactive")
  fi

  # Check VPS secrets
  local secrets_exists=0 secrets_mode="missing"
  if [[ -f "$secrets_file" ]]; then
    secrets_exists=1
    secrets_mode=$(stat -c '%a' "$secrets_file" 2>/dev/null || stat -f '%Lp' "$secrets_file" 2>/dev/null || echo "unknown")
  fi

  # ── Cloudflare nanok env ──
  local cf_nanok_env="missing"
  local cf_nanok_worker="" cf_nanok_url="" cf_nanok_sub_path="" cf_nanok_deploy=""
  local cf_nanok_profile_upload="" cf_nanok_verify=""
  local cf_nanok_sub_token="" cf_nanok_admin_token="" cf_nanok_kv=""
  local cf_admin_env_exists="false"
  local cf_sub_token_fp="" cf_admin_token_fp=""

  # Try to find .cloudflare.local.env
  local cf_env_file=""
  for candidate in \
    "${REPO_DIR}/.cloudflare.local.env" \
    "${config_dir}/cloudflare.local.env" \
    "/root/.nanok-cf-admin.env"; do
    if [[ -f "$candidate" ]]; then
      cf_env_file="$candidate"
      break
    fi
  done

  if [[ -n "$cf_env_file" ]] && [[ -f "$cf_env_file" ]]; then
    cf_nanok_env="present"
    cf_nanok_worker=$(read_env_value "$cf_env_file" "NANOK_WORKER_NAME")
    cf_nanok_url=$(read_env_value "$cf_env_file" "NANOK_ROUTE_URL")
    cf_nanok_sub_path=$(read_env_value "$cf_env_file" "SUB_PATH")
    cf_nanok_deploy=$(read_env_value "$cf_env_file" "NANOBK_DEPLOY_STATUS")
    [[ -z "$cf_nanok_deploy" ]] && cf_nanok_deploy="unknown"
    cf_nanok_profile_upload=$(read_env_value "$cf_env_file" "NANOBK_PROFILE_UPLOAD_STATUS")
    [[ -z "$cf_nanok_profile_upload" ]] && cf_nanok_profile_upload="unknown"
    cf_nanok_verify=$(read_env_value "$cf_env_file" "NANOBK_VERIFY_STATUS")
    [[ -z "$cf_nanok_verify" ]] && cf_nanok_verify="unknown"
    cf_nanok_kv=$(read_env_value "$cf_env_file" "SUB_STORE_KV_NAMESPACE_ID")

    local cf_sub_token cf_admin_token
    cf_sub_token=$(read_env_value "$cf_env_file" "SUB_TOKEN")
    if [[ -n "$cf_sub_token" ]]; then
      cf_nanok_sub_token="present"
      cf_sub_token_fp=$(fingerprint_secret "$cf_sub_token")
    fi
    cf_admin_token=$(read_env_value "$cf_env_file" "ADMIN_TOKEN")
    if [[ -n "$cf_admin_token" ]]; then
      cf_nanok_admin_token="present"
      cf_admin_token_fp=$(fingerprint_secret "$cf_admin_token")
    fi
  fi

  # Check admin env separately
  if [[ -f "/root/.nanok-cf-admin.env" ]]; then
    cf_admin_env_exists="true"
  fi

  # ── Cloudflare nanob env ──
  local cf_nanob_env="missing"
  local cf_nanob_worker="" cf_nanob_url="" cf_nanob_path=""
  local cf_nanob_deploy="" cf_nanob_verify=""
  local cf_nanob_token="" cf_nanob_token_fp=""
  local cf_nanob_geo_kv="" cf_nanob_edge_host=""

  local nanob_env_file=""
  for candidate in \
    "${REPO_DIR}/.nanob.local.env" \
    "${config_dir}/nanob.local.env"; do
    if [[ -f "$candidate" ]]; then
      nanob_env_file="$candidate"
      break
    fi
  done

  if [[ -n "$nanob_env_file" ]] && [[ -f "$nanob_env_file" ]]; then
    cf_nanob_env="present"
    cf_nanob_worker=$(read_env_value "$nanob_env_file" "NANOB_WORKER_NAME")
    cf_nanob_url=$(read_env_value "$nanob_env_file" "NANOB_ROUTE_URL")
    cf_nanob_path=$(read_env_value "$nanob_env_file" "NANOB_PATH")
    cf_nanob_deploy=$(read_env_value "$nanob_env_file" "NANOB_DEPLOY_STATUS")
    [[ -z "$cf_nanob_deploy" ]] && cf_nanob_deploy="unknown"
    cf_nanob_verify=$(read_env_value "$nanob_env_file" "NANOB_VERIFY_STATUS")
    [[ -z "$cf_nanob_verify" ]] && cf_nanob_verify="unknown"
    cf_nanob_geo_kv=$(read_env_value "$nanob_env_file" "NANOB_GEO_KV_NAMESPACE_ID")
    cf_nanob_edge_host=$(read_env_value "$nanob_env_file" "EDGE_HOST")

    local cf_nanob_token_val
    cf_nanob_token_val=$(read_env_value "$nanob_env_file" "NANOB_TOKEN")
    if [[ -n "$cf_nanob_token_val" ]]; then
      cf_nanob_token="present"
      cf_nanob_token_fp=$(fingerprint_secret "$cf_nanob_token_val")
    fi
  fi

  # ── Compute ok and warnings ──
  local status_ok="true"
  local warnings=()

  if [[ "$config_exists" != "1" ]]; then
    status_ok="false"
    warnings+=("config.env missing")
  fi
  if [[ "$profile_exists" != "1" ]]; then
    status_ok="false"
    warnings+=("profile.current.json missing")
  elif [[ "$has_hy2" != "1" || "$has_tuic" != "1" || "$has_reality" != "1" || "$has_trojan" != "1" ]]; then
    status_ok="false"
    warnings+=("profile incomplete (missing protocol sections)")
  fi
  if [[ "$secrets_exists" == "1" && "$secrets_mode" != "600" ]]; then
    warnings+=("secrets.private.env mode ${secrets_mode} (should be 600)")
  fi
  if [[ "$cf_nanok_env" == "missing" ]]; then
    warnings+=("cloudflare local env missing")
  fi

  # ── Output ──
  if [[ "$JSON_OUT" == "1" ]]; then
    local secrets_mode_ok="true"
    [[ "$secrets_mode" != "600" ]] && secrets_mode_ok="false"

    local warnings_json="["
    local first=1
    for w in "${warnings[@]}"; do
      [[ $first -eq 1 ]] && first=0 || warnings_json+=","
      warnings_json+="$(json_escape "$w")"
    done
    warnings_json+="]"

    cat <<EOF
{
  "ok": ${status_ok},
  "configDir": $(json_escape "${config_dir}"),
  "domain": $(json_escape "${domain}"),
  "vpsIp": $(json_escape "${vps_ip}"),
  "geo": $(json_escape "${geo}"),
  "profile": {
    "exists": $([ "$profile_exists" == "1" ] && echo "true" || echo "false"),
    "updatedAt": $(json_escape "${profile_updated}"),
    "hy2": $([ "$has_hy2" == "1" ] && echo "true" || echo "false"),
    "tuic": $([ "$has_tuic" == "1" ] && echo "true" || echo "false"),
    "reality": $([ "$has_reality" == "1" ] && echo "true" || echo "false"),
    "trojan": $([ "$has_trojan" == "1" ] && echo "true" || echo "false")
  },
  "services": {
    "hy2": $(json_escape "${svc_hy2}"),
    "tuic": $(json_escape "${svc_tuic}"),
    "reality": $(json_escape "${svc_reality}"),
    "trojan": $(json_escape "${svc_trojan}")
  },
  "security": {
    "secretsExists": $([ "$secrets_exists" == "1" ] && echo "true" || echo "false"),
    "secretsMode": $(json_escape "${secrets_mode}"),
    "secretsModeOk": ${secrets_mode_ok}
  },
  "cloudflare": {
    "nanok": {
      "envExists": $([ "$cf_nanok_env" == "present" ] && echo "true" || echo "false"),
      "workerName": $(json_escape "${cf_nanok_worker}"),
      "routeUrl": $(json_escape "${cf_nanok_url}"),
      "subPath": $(json_escape "${cf_nanok_sub_path}"),
      "deployStatus": $(json_escape "${cf_nanok_deploy}"),
      "profileUploadStatus": $(json_escape "${cf_nanok_profile_upload}"),
      "verifyStatus": $(json_escape "${cf_nanok_verify}"),
      "subTokenPresent": $([ "$cf_nanok_sub_token" == "present" ] && echo "true" || echo "false"),
      "subTokenFingerprint": $(json_escape "${cf_sub_token_fp}"),
      "adminTokenPresent": $([ "$cf_nanok_admin_token" == "present" ] && echo "true" || echo "false"),
      "adminTokenFingerprint": $(json_escape "${cf_admin_token_fp}"),
      "kvNamespacePresent": $([ -n "$cf_nanok_kv" ] && echo "true" || echo "false"),
      "adminEnvExists": ${cf_admin_env_exists}
    },
    "nanob": {
      "envExists": $([ "$cf_nanob_env" == "present" ] && echo "true" || echo "false"),
      "workerName": $(json_escape "${cf_nanob_worker}"),
      "routeUrl": $(json_escape "${cf_nanob_url}"),
      "path": $(json_escape "${cf_nanob_path}"),
      "deployStatus": $(json_escape "${cf_nanob_deploy}"),
      "verifyStatus": $(json_escape "${cf_nanob_verify}"),
      "tokenPresent": $([ "$cf_nanob_token" == "present" ] && echo "true" || echo "false"),
      "tokenFingerprint": $(json_escape "${cf_nanob_token_fp}"),
      "geoKvNamespacePresent": $([ -n "$cf_nanob_geo_kv" ] && echo "true" || echo "false"),
      "edgeHostConfigured": $([ -n "$cf_nanob_edge_host" ] && echo "true" || echo "false")
    }
  },
  "warnings": ${warnings_json}
}
EOF
  else
    echo ""
    echo -e "${BOLD}NanoBK Status${NC}"
    echo ""
    echo "  Config:"
    echo "    config-dir:  ${config_dir}"
    echo "    domain:      ${domain:-<not set>}"
    echo "    vps-ip:      ${vps_ip:-<not set>}"
    echo "    geo:         ${geo:-<not set>}"
    echo ""
    echo "  Profile:"
    if [[ "$profile_exists" == "1" ]]; then
      echo "    updatedAt:   ${profile_updated:-<unknown>}"
      echo "    hy2:         $([ "$has_hy2" == "1" ] && echo "present" || echo "missing")"
      echo "    tuic:        $([ "$has_tuic" == "1" ] && echo "present" || echo "missing")"
      echo "    reality:     $([ "$has_reality" == "1" ] && echo "present" || echo "missing")"
      echo "    trojan:      $([ "$has_trojan" == "1" ] && echo "present" || echo "missing")"
    else
      echo "    <profile not found>"
    fi
    echo ""
    echo "  Services:"
    echo "    ${hy2_service}:      ${svc_hy2}"
    echo "    ${tuic_service}:     ${svc_tuic}"
    echo "    ${reality_service}:  ${svc_reality}"
    echo "    ${trojan_service}:   ${svc_trojan}"
    echo ""
    echo "  Security:"
    if [[ "$secrets_exists" == "1" ]]; then
      local mode_label="${secrets_mode}"
      [[ "$secrets_mode" != "600" ]] && mode_label="${secrets_mode} (should be 600)"
      echo "    secrets.private.env: mode ${mode_label}"
    else
      echo "    secrets.private.env: missing"
    fi
    echo ""
    echo "  Cloudflare:"
    echo "    nanok env:       ${cf_nanok_env}"
    if [[ "$cf_nanok_env" == "present" ]]; then
      echo "    nanok worker:    ${cf_nanok_worker:-<not set>}"
      echo "    nanok url:       ${cf_nanok_url:-<not set>}"
      echo "    nanok deploy:    ${cf_nanok_deploy}"
      echo "    profile upload:  ${cf_nanok_profile_upload}"
      echo "    verify:          ${cf_nanok_verify}"
      echo "    sub token:       ${cf_nanok_sub_token:-missing}${cf_nanok_sub_token:+ fingerprint=${cf_sub_token_fp}}"
      echo "    admin token:     ${cf_nanok_admin_token:-missing}${cf_nanok_admin_token:+ fingerprint=${cf_admin_token_fp}}"
      echo "    kv namespace:    $([ -n "$cf_nanok_kv" ] && echo "present" || echo "missing")"
    fi
    echo ""
    echo "  Aggregator:"
    if [[ "$cf_nanob_env" == "present" ]]; then
      echo "    nanob env:       ${cf_nanob_env}"
      echo "    nanob worker:    ${cf_nanob_worker:-<not set>}"
      echo "    nanob url:       ${cf_nanob_url:-<not set>}"
      echo "    nanob deploy:    ${cf_nanob_deploy}"
      echo "    nanob verify:    ${cf_nanob_verify}"
      echo "    nanob token:     ${cf_nanob_token:-missing}${cf_nanob_token:+ fingerprint=${cf_nanob_token_fp}}"
      echo "    geo kv:          $([ -n "$cf_nanob_geo_kv" ] && echo "present" || echo "missing")"
      echo "    edge host:       $([ -n "$cf_nanob_edge_host" ] && echo "configured" || echo "disabled")"
    else
      echo "    nanob: not configured"
    fi
    if [[ ${#warnings[@]} -gt 0 ]]; then
      echo ""
      echo "  Warnings:"
      for w in "${warnings[@]}"; do
        echo "    - ${w}"
      done
    fi
    echo ""
  fi
}

# ── doctor ──────────────────────────────────────────────────────────────────

cmd_doctor() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run) DRY_RUN=1 ;;
      --json)    JSON_OUT=1 ;;
      *) die "Unknown doctor option: $1" ;;
    esac
    shift
  done

  if [[ "$JSON_OUT" == "1" ]]; then
    echo '{"ok":true,"command":"doctor","note":"JSON doctor output is planned for v1.x; raw output is text-only in v0.8"}'
    echo ""
  fi
  run_script "运行环境诊断" bash "$REPO_DIR/installer/doctor.sh" || {
    local exit_code=$?
    warn "doctor 退出码: ${exit_code}（有错误或警告）"
    return $exit_code
  }
}

# ── install ─────────────────────────────────────────────────────────────────

cmd_install() {
  local cmd=(bash "$REPO_DIR/installer/install.sh" --repo-dir "$REPO_DIR")
  local has_dry_run=0
  for arg in "$@"; do
    [[ "$arg" == "--dry-run" ]] && has_dry_run=1
  done
  [[ "$DRY_RUN" == "1" && "$has_dry_run" == "0" ]] && cmd+=(--dry-run)
  cmd+=("$@")

  run_script "启动安装器" "${cmd[@]}"
}

# ── cf deploy ───────────────────────────────────────────────────────────────

cmd_cf_deploy() {
  local cmd=(bash "$REPO_DIR/installer/install-cloudflare.sh")
  local has_dry_run=0
  for arg in "$@"; do
    [[ "$arg" == "--dry-run" ]] && has_dry_run=1
  done
  [[ "$DRY_RUN" == "1" && "$has_dry_run" == "0" ]] && cmd+=(--dry-run)
  cmd+=("$@")

  run_script "部署 Cloudflare Workers" "${cmd[@]}"
}

# ── cf verify ───────────────────────────────────────────────────────────────

cmd_cf_verify() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    nanok)
      local cmd=(bash "$REPO_DIR/installer/install-cloudflare.sh" --verify-nanok-only)
      [[ "$DRY_RUN" == "1" ]] && cmd+=(--dry-run)
      run_script "验证 nanok 订阅" "${cmd[@]}"
      ;;
    nanob)
      local cmd=(bash "$REPO_DIR/installer/install-cloudflare.sh" --verify-nanob-only)
      [[ "$DRY_RUN" == "1" ]] && cmd+=(--dry-run)
      run_script "验证 nanob 订阅" "${cmd[@]}"
      ;;
    "")
      # Verify both
      cmd_cf_verify nanok
      cmd_cf_verify nanob
      ;;
    *)
      die "Usage: nanobk cf verify [nanok|nanob]"
      ;;
  esac
}

cmd_cf_install_admin_env() {
  local local_env="${REPO_DIR}/.cloudflare.local.env"
  local target="/root/.nanok-cf-admin.env"

  if [[ ! -f "$local_env" ]]; then
    die "Cloudflare local env not found: ${local_env}\nRun: bash installer/install-cloudflare.sh first"
  fi

  local adm_token adm_current adm_update
  adm_token=$(read_env_value "$local_env" "ADMIN_TOKEN" 2>/dev/null || echo "")
  adm_current=$(read_env_value "$local_env" "ADMIN_CURRENT_URL" 2>/dev/null || echo "")
  adm_update=$(read_env_value "$local_env" "ADMIN_UPDATE_URL" 2>/dev/null || echo "")

  if [[ -z "$adm_token" ]] || [[ -z "$adm_current" ]] || [[ -z "$adm_update" ]]; then
    die "Cloudflare local env is missing required fields (ADMIN_TOKEN, ADMIN_CURRENT_URL, ADMIN_UPDATE_URL)"
  fi

  # Write to temp file (never put token in sudo argv)
  local tmp_admin
  tmp_admin=$(mktemp)
  chmod 600 "$tmp_admin"
  cat > "$tmp_admin" <<ENVEOF
ADMIN_TOKEN="${adm_token}"
ADMIN_CURRENT_URL="${adm_current}"
ADMIN_UPDATE_URL="${adm_update}"
ENVEOF

  if [[ $EUID -eq 0 ]]; then
    install -m 600 "$tmp_admin" "$target"
    rm -f "$tmp_admin"
    ok "Admin env installed: ${target} (mode 600)"
  else
    if command -v sudo &>/dev/null; then
      sudo install -m 600 "$tmp_admin" "$target" 2>/dev/null && {
        rm -f "$tmp_admin"
        ok "Admin env installed via sudo: ${target} (mode 600)"
      } || {
        rm -f "$tmp_admin"
        die "无法写入 ${target}，需要 sudo 权限。"
      }
    else
      rm -f "$tmp_admin"
      die "无法写入 ${target}，需要 sudo 权限。"
    fi
  fi
}

# ── rotate ──────────────────────────────────────────────────────────────────

cmd_rotate() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    all|hy2|tuic|reality|trojan)
      local cmd=(bash "$REPO_DIR/vps/scripts/rotate-keys.sh" --protocol "$subcmd")
      local has_dry_run=0
      for arg in "$@"; do
        [[ "$arg" == "--dry-run" ]] && has_dry_run=1
      done
      [[ "$DRY_RUN" == "1" && "$has_dry_run" == "0" ]] && cmd+=(--dry-run)
      cmd+=("$@")
      run_script "换密钥 (${subcmd})" "${cmd[@]}"
      ;;
    "")
      die "Usage: nanobk rotate <all|hy2|tuic|reality|trojan> [args...]"
      ;;
    *)
      die "Unknown rotate subcommand: ${subcmd}. Use: nanobk rotate <all|hy2|tuic|reality|trojan>"
      ;;
  esac
}

# ── test ────────────────────────────────────────────────────────────────────

cmd_test() {
  local run_all=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --all) run_all=1 ;;
      --dry-run) DRY_RUN=1 ;;
      *) die "Unknown test option: $1" ;;
    esac
    shift
  done

  local scripts=(
    "$REPO_DIR/tests/bootstrap-dry-run.sh"
    "$REPO_DIR/tests/render-install-vps.sh"
    "$REPO_DIR/tests/rotate-render-only.sh"
  )

  if [[ "$run_all" == "1" ]]; then
    scripts+=(
      "$REPO_DIR/tests/wrangler-nanok-dry-run.sh"
      "$REPO_DIR/tests/wrangler-nanob-dry-run.sh"
    )
  fi

  local failed=0
  for script in "${scripts[@]}"; do
    local label
    label="$(basename "$script" .sh)"

    if [[ "$DRY_RUN" == "1" ]]; then
      echo -e "  ${CYAN}[DRY-RUN]${NC} bash ${script}"
      continue
    fi

    log "运行: ${label}"
    if bash "$script"; then
      ok "${label}: passed"
    else
      warn "${label}: failed"
      failed=$((failed + 1))
    fi
    echo ""
  done

  if [[ "$DRY_RUN" == "1" ]]; then
    return 0
  fi

  if [[ $failed -gt 0 ]]; then
    die "${failed} test(s) failed"
  fi
  ok "All tests passed"
}

# ── Argument parsing ────────────────────────────────────────────────────────

parse_global_args() {
  CMD_ARGS=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo-dir)   REPO_DIR="$2"; shift 2 ;;
      --dry-run)    DRY_RUN=1; shift ;;
      --json)       JSON_OUT=1; shift ;;
      --help|-h)    cmd_help; exit 0 ;;
      --version|-v) cmd_version; exit 0 ;;
      -*)           die "Unknown global option: $1. Use --help for usage." ;;
      *)            CMD_ARGS=("$@"); return ;;
    esac
  done
}

# ── Main ────────────────────────────────────────────────────────────────────

main() {
  parse_global_args "$@"

  local command="${CMD_ARGS[0]:-}"
  local cmd_rest=()
  if [[ ${#CMD_ARGS[@]} -gt 1 ]]; then
    cmd_rest=("${CMD_ARGS[@]:1}")
  fi

  resolve_repo_dir

  case "$command" in
    status)       cmd_status ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    doctor)       cmd_doctor ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    install)      cmd_install ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    install-cli)  cmd_install_cli ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    cf)
      local cf_sub="${cmd_rest[0]:-}"
      local cf_rest=()
      if [[ ${#cmd_rest[@]} -gt 1 ]]; then
        cf_rest=("${cmd_rest[@]:1}")
      fi
      case "$cf_sub" in
        deploy)  cmd_cf_deploy ${cf_rest[@]+"${cf_rest[@]}"} ;;
        verify)  cmd_cf_verify ${cf_rest[@]+"${cf_rest[@]}"} ;;
        install-admin-env) cmd_cf_install_admin_env ;;
        *)       die "Usage: nanobk cf <deploy|verify|install-admin-env> [args...]" ;;
      esac
      ;;
    rotate)   cmd_rotate ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    test)     cmd_test ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    version)  cmd_version ;;
    "")       cmd_help ;;
    *)        die "Unknown command: ${command}. Use --help for usage." ;;
  esac
}

main "$@"
