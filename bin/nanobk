                    [[ $# -ge 2 ]] || die "cf dns profile replace preview: --node needs a value"
                    args+=("$1" "$2"); shift 2 ;;
                  --ipv4)
                    [[ $# -ge 2 ]] || die "cf dns profile replace preview: --ipv4 needs a value"
                    args+=("$1" "$2"); shift 2 ;;
                  --ipv6)
                    [[ $# -ge 2 ]] || die "cf dns profile replace preview: --ipv6 needs a value"
                    args+=("$1" "$2"); shift 2 ;;
                  --output)
                    [[ $# -ge 2 ]] || die "cf dns profile replace preview: --output needs a path"
                    args+=("$1" "$2"); shift 2 ;;
                  --allow-production-output)
                    args+=("--allow-production-output"); shift ;;
                  --confirm-hostname)
                    [[ $# -ge 2 ]] || die "cf dns profile replace preview: --confirm-hostname needs a value"
                    args+=("$1" "$2"); shift 2 ;;
                  --allow-documentation-ips)
                    args+=("--allow-documentation-ips"); shift ;;
                  --json)
                    args+=("--json"); shift ;;
                  --help|-h)
                    args+=("--help"); shift ;;
                  --dry-run)
                    echo -e "  ${CYAN}[DRY-RUN]${NC} nanobk cf dns profile replace preview would run; raw zone, IP, confirmation, and output path arguments are hidden; no filesystem checks performed"
                    return 0 ;;
                  *)
                    die "cf dns profile replace preview: unknown option: $1"
                    ;;
                esac
              done
              # Respect global --dry-run (sanitized)
              if [[ "$DRY_RUN" == "1" ]]; then
                echo -e "  ${CYAN}[DRY-RUN]${NC} nanobk cf dns profile replace preview would run; raw zone, IP, confirmation, and output path arguments are hidden; no filesystem checks performed"
                return 0
              fi
              "${args[@]}"
              ;;
            "")
              die "Usage: nanobk cf dns profile replace <preview> [options...]"
              ;;
            *)
              die "Unknown cf dns profile replace subcommand: ${replace_sub}. Use: nanobk cf dns profile replace preview"
              ;;
          esac
          ;;
        backup)
          local args=(python3 "$REPO_DIR/lib/nanobk_cf_dns_profile.py" backup)
          while [[ $# -gt 0 ]]; do
            case "$1" in
              --profile)
                [[ $# -ge 2 ]] || die "cf dns profile backup: --profile needs a path"
                args+=("$1" "$2"); shift 2 ;;
              --allow-production-output)
                args+=("--allow-production-output"); shift ;;
              --confirm-hostname)
                [[ $# -ge 2 ]] || die "cf dns profile backup: --confirm-hostname needs a value"
                args+=("$1" "$2"); shift 2 ;;
              --yes)
                args+=("--yes"); shift ;;
              --json)
                args+=("--json"); shift ;;
              --help|-h)
                args+=("--help"); shift ;;
              --dry-run)
                echo -e "  ${CYAN}[DRY-RUN]${NC} nanobk cf dns profile backup would run; raw confirmation and profile path arguments are hidden; no filesystem checks performed"
                return 0 ;;
              *)
                die "cf dns profile backup: unknown option: $1"
                ;;
            esac
          done
          # Respect global --dry-run (sanitized)
          if [[ "$DRY_RUN" == "1" ]]; then
            echo -e "  ${CYAN}[DRY-RUN]${NC} nanobk cf dns profile backup would run; raw confirmation and profile path arguments are hidden; no filesystem checks performed"
            return 0
          fi
          "${args[@]}"
          ;;
        rollback)
          local rollback_sub="${1:-}"
          shift 2>/dev/null || true
          case "$rollback_sub" in
            preview)
              local args=(python3 "$REPO_DIR/lib/nanobk_cf_dns_profile.py" rollback preview)
              while [[ $# -gt 0 ]]; do
                case "$1" in
                  --backup-id)
                    [[ $# -ge 2 ]] || die "cf dns profile rollback preview: --backup-id needs a value"
                    args+=("$1" "$2"); shift 2 ;;
                  --allow-production-output)
                    args+=("--allow-production-output"); shift ;;
                  --confirm-hostname)
                    [[ $# -ge 2 ]] || die "cf dns profile rollback preview: --confirm-hostname needs a value"
                    args+=("$1" "$2"); shift 2 ;;
                  --json)
                    args+=("--json"); shift ;;
                  --help|-h)
                    args+=("--help"); shift ;;
                  --dry-run)
                    echo -e "  ${CYAN}[DRY-RUN]${NC} nanobk cf dns profile rollback preview would run; raw backup-id and confirmation arguments are hidden; no filesystem checks performed"
                    return 0 ;;
                  *)
                    die "cf dns profile rollback preview: unknown option: $1"
                    ;;
                esac
              done
              # Respect global --dry-run (sanitized)
              if [[ "$DRY_RUN" == "1" ]]; then
                echo -e "  ${CYAN}[DRY-RUN]${NC} nanobk cf dns profile rollback preview would run; raw backup-id and confirmation arguments are hidden; no filesystem checks performed"
                return 0
              fi
              "${args[@]}"
              ;;
            execute)
              local args=(python3 "$REPO_DIR/lib/nanobk_cf_dns_profile.py" rollback execute)
              while [[ $# -gt 0 ]]; do
                case "$1" in
                  --backup-id)
                    [[ $# -ge 2 ]] || die "cf dns profile rollback execute: --backup-id needs a value"
                    args+=("$1" "$2"); shift 2 ;;
                  --allow-production-output)
                    args+=("--allow-production-output"); shift ;;
                  --confirm-hostname)
                    [[ $# -ge 2 ]] || die "cf dns profile rollback execute: --confirm-hostname needs a value"
                    args+=("$1" "$2"); shift 2 ;;
                  --confirm-rollback-profile)
                    [[ $# -ge 2 ]] || die "cf dns profile rollback execute: --confirm-rollback-profile needs a value"
                    args+=("$1" "$2"); shift 2 ;;
                  --yes)
                    args+=("--yes"); shift ;;
                  --json)
                    args+=("--json"); shift ;;
                  --help|-h)
                    args+=("--help"); shift ;;
                  --dry-run)
                    echo -e "  ${CYAN}[DRY-RUN]${NC} nanobk cf dns profile rollback execute would run; raw backup-id, confirmation, and rollback phrase arguments are hidden; no filesystem checks performed"
                    return 0 ;;
                  *)
                    die "cf dns profile rollback execute: unknown option: $1"
                    ;;
                esac
              done
              # Respect global --dry-run (sanitized)
              if [[ "$DRY_RUN" == "1" ]]; then
                echo -e "  ${CYAN}[DRY-RUN]${NC} nanobk cf dns profile rollback execute would run; raw backup-id, confirmation, and rollback phrase arguments are hidden; no filesystem checks performed"
                return 0
              fi
              "${args[@]}"
              ;;
            "")
              die "Usage: nanobk cf dns profile rollback <preview|execute> [options...]"
              ;;
            *)
              die "Unknown cf dns profile rollback subcommand: ${rollback_sub}. Use: nanobk cf dns profile rollback <preview|execute>"
              ;;
          esac
          ;;
        "")
          die "Usage: nanobk cf dns profile <preview|generate|replace|backup|rollback> [options...]"
          ;;
        *)
          die "Unknown cf dns profile subcommand: ${profile_sub}. Use: nanobk cf dns profile <preview|generate|replace|backup|rollback>"
          ;;
      esac
      ;;

    planner)
      cmd_cf_dns_planner "$@"
      ;;

    apply-plan)
      cmd_cf_dns_apply_plan "$@"
      ;;

    "")
      die "Usage: nanobk cf dns <plan|planner|apply-plan|validate-profile|apply|readiness|target|availability|report|profile> [options...]"
      ;;

    *)
      die "Unknown cf dns subcommand: ${dns_sub}. Use: nanobk cf dns <plan|planner|apply-plan|validate-profile|apply|readiness|target|availability|report|profile>"
      ;;
  esac
}

# ── cf zones ──────────────────────────────────────────────────────────────

cmd_cf_zones() {
  local zones_sub="${1:-}"
  shift 2>/dev/null || true

  case "$zones_sub" in
    list)
      local args=(python3 "$REPO_DIR/lib/nanobk_cf_zones.py" list)
      local json_mode=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --api-env)
            [[ $# -ge 2 ]] || die "cf zones list: --api-env needs a path argument"
            args+=("$1" "$2"); shift 2 ;;
          --json)
            json_mode=1; args+=("--json"); shift ;;
          --help|-h)
            args+=("--help"); shift ;;
          --dry-run)
            print_cmd "${args[@]}"
            echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
            return 0 ;;
          *)
            die "cf zones list: unknown option: $1"
            ;;
        esac
      done

      if [[ "$DRY_RUN" == "1" ]]; then
        print_cmd "${args[@]}"
        echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
        return 0
      fi

      "${args[@]}"
      ;;

    "")
      die "Usage: nanobk cf zones list --api-env PATH [--json]"
      ;;

    *)
      die "Unknown cf zones subcommand: ${zones_sub}. Use: nanobk cf zones list"
      ;;
  esac
}

# ── cf connect ──────────────────────────────────────────────────────────────

cmd_cf_connect() {
  local api_token="" api_env="" auto_yes=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --api-token)
        [[ $# -ge 2 ]] || die "cf connect: --api-token needs a value"
        api_token="$2"; shift 2 ;;
      --api-env)
        [[ $# -ge 2 ]] || die "cf connect: --api-env needs a path"
        api_env="$2"; shift 2 ;;
      --yes)
        auto_yes=1; shift ;;
      --json)
        JSON_OUT=1; shift ;;
      --dry-run)
        DRY_RUN=1; shift ;;
      --help|-h)
        echo "Usage: nanobk cf connect [--api-token TOKEN] [--api-env PATH] [--yes] [--json]"
        echo ""
        echo "  连接 Cloudflare 账户并选择域名。"
        echo "  验证 API token，列出域名，保存到 setup profile。"
        echo "  只读操作：不会创建 DNS，不会修改 Cloudflare。"
        return 0 ;;
      *)
        die "cf connect: unknown option: $1"
        ;;
    esac
  done

  if [[ "$DRY_RUN" == "1" ]]; then
    echo -e "  ${CYAN}[DRY-RUN]${NC} cf connect command prepared"
    echo "  token: <redacted>"
    echo "  No Cloudflare API call will be made."
    return 0
  fi

  local args=(python3 "$REPO_DIR/lib/nanobk_cf_onboarding.py")
  [[ -n "$api_token" ]] && args+=(--api-token "$api_token")
  [[ -n "$api_env" ]] && args+=(--api-env "$api_env")
  [[ "$auto_yes" == "1" ]] && args+=(--yes)
  [[ "$JSON_OUT" == "1" ]] && args+=(--json)

  "${args[@]}"
}

# ── home / setup status ───────────────────────────────────────────────────

cmd_home() {
  local use_json=0
  local use_legacy_json=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)
        use_json=1; shift ;;
      --legacy-json)
        use_legacy_json=1; shift ;;
      --help|-h)
        echo "Usage: nanobk home [--json] [--legacy-json]"
        echo ""
        echo "  Show NanoBK beginner-friendly home screen."
        echo "  显示 NanoBK 小白首页和状态概览。"
        echo "  --json         v2.4 safe beginner JSON (no secrets, no network)"
        echo "  --legacy-json  old setup status JSON format (backward compat)"
        echo "  Read-only. No DNS mutation. No Cloudflare mutation."
        return 0 ;;
      --dry-run)
        echo -e "  ${CYAN}[DRY-RUN]${NC} home command prepared"
        echo "  No DNS mutation will be performed."
        return 0 ;;
      *)
        die "home: unknown option: $1"
        ;;
    esac
  done
  if [[ "$DRY_RUN" == "1" ]]; then
    echo -e "  ${CYAN}[DRY-RUN]${NC} home command prepared"
    echo "  No DNS mutation will be performed."
    return 0
  fi
  if [[ "$use_legacy_json" == "1" ]]; then
    # Legacy JSON: use old setup status module for backward compat
    python3 "$REPO_DIR/lib/nanobk_setup_status.py" home --json
  elif [[ "$use_json" == "1" ]]; then
    # JSON: use v2.4 safe beginner JSON (no secrets, no network)
    python3 "$REPO_DIR/lib/nanobk_cli_home.py" home --json
  else
    # Text: use beginner-friendly CLI home
    python3 "$REPO_DIR/lib/nanobk_cli_home.py" home
  fi
}

# ── beginner ─────────────────────────────────────────────────────────────

cmd_beginner() {
  local subcommand=""
  local use_json=0
  local extra_args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)
        use_json=1; shift ;;
      status)
        subcommand="status"; shift ;;
      flow)
        subcommand="flow"; shift ;;
      subdomain)
        subcommand="subdomain"; shift
        extra_args=("$@")
        break
        ;;
      ip)
        subcommand="ip"; shift
        extra_args=("$@")
        break
        ;;
      gate)
        subcommand="gate"; shift
        extra_args=("$@")
        break
        ;;
      production)
        subcommand="production"; shift
        extra_args=("$@")
        break
        ;;
      --help|-h)
        echo "Usage: nanobk beginner [--json]"
        echo "       nanobk beginner status [--json]"
        echo "       nanobk beginner flow [--json]"
        echo "       nanobk beginner subdomain [--json] [--domain DOMAIN]"
        echo "       nanobk beginner ip [--json] [--ipv4 ADDR] [--ipv6 ADDR]"
        echo "       nanobk beginner gate dns|cert|token [--json]"
        echo "       nanobk beginner production [--json]"
        echo ""
        echo "  Show beginner-friendly setup flow and status."
        echo "  显示新手设置流程和状态概览。"
        echo "  subdomain: 检查子域名是否可用"
        echo "  ip: 显示 VPS IP 检测状态"
        echo "  gate: 预览 DNS / 证书 / 订阅密钥 gate（只读预览）"
        echo "  Read-only. No DNS mutation. No Cloudflare mutation."
        return 0 ;;
      --dry-run)
        echo -e "  ${CYAN}[DRY-RUN]${NC} beginner command prepared"
        echo "  No DNS mutation will be performed."
        return 0 ;;
      *)
        die "beginner: unknown option: $1"
        ;;
    esac
  done
  if [[ "$DRY_RUN" == "1" ]]; then
    echo -e "  ${CYAN}[DRY-RUN]${NC} beginner command prepared"
    echo "  No DNS mutation will be performed."
    return 0
  fi
  if [[ "$subcommand" == "subdomain" ]]; then
    local args=(python3 "$REPO_DIR/lib/nanobk_subdomain_conflict_ux.py" check)
    args+=(${extra_args[@]+"${extra_args[@]}"})
    [[ "$use_json" == "1" ]] && args+=("--json")
    "${args[@]}"
  elif [[ "$subcommand" == "ip" ]]; then
    local args=(python3 "$REPO_DIR/lib/nanobk_ip_friendly_ux.py" status)
    args+=(${extra_args[@]+"${extra_args[@]}"})
    [[ "$use_json" == "1" ]] && args+=("--json")
    "${args[@]}"
  elif [[ "$subcommand" == "gate" ]]; then
    local args=(python3 "$REPO_DIR/lib/nanobk_friendly_gate_wrappers.py")
    args+=(${extra_args[@]+"${extra_args[@]}"})
    [[ "$use_json" == "1" ]] && args+=("--json")
    "${args[@]}"
  elif [[ "$subcommand" == "production" ]]; then
    local args=(python3 "$REPO_DIR/lib/nanobk_production_setup_spine.py")
    args+=(${extra_args[@]+"${extra_args[@]}"})
    [[ "$use_json" == "1" ]] && args+=("--json")
    "${args[@]}"
  else
    local args=(python3 "$REPO_DIR/lib/nanobk_beginner_flow.py")
    [[ -n "$subcommand" ]] && args+=("$subcommand")
    [[ "$use_json" == "1" ]] && args+=("--json")
    "${args[@]}"
  fi
}

