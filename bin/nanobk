#!/usr/bin/env bash
# NanoBK Proxy Suite — Unified CLI
#
# Stable command-line interface for NanoBK management.
# Designed for use by future Telegram Bot / Web Panel (1.x).
#
# Usage:
#   nanobk                    Interactive console (TTY) or entry help
#   nanobk console            Interactive console (explicit)
#   nanobk status
#   nanobk doctor
#   nanobk install --mode commands
#   nanobk cf deploy --dry-run
#   nanobk rotate all --skip-cloudflare
#   nanobk test
#   nanobk install-cli
#   nanobk version

set -Eeuo pipefail

# ── Version ─────────────────────────────────────────────────────────────────

NANOBK_VERSION="2.1.1"

# ── Colors ──────────────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

log()   { echo -e "${BLUE}[INFO]${NC}  $*"; }
ok()    { echo -e "${GREEN}[OK]${NC}    $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; }
err()   { echo -e "${RED}[ERROR]${NC} $*" >&2; }
die()   { err "$*"; exit 1; }

# ── Global flags ────────────────────────────────────────────────────────────

DRY_RUN=0
JSON_OUT=0
REPO_DIR=""
CONFIG_DIR="/etc/nanobk"

# ── JSON helpers ────────────────────────────────────────────────────────────

json_escape() {
  local input="$1"
  if command -v python3 &>/dev/null; then
    printf '%s' "$input" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()), end="")'
  else
    local result="$input"
    result="${result//\\/\\\\}"
    result="${result//\"/\\\"}"
    result="${result//$'\t'/\\t}"
    result="${result//$'\n'/\\n}"
    result="${result//$'\r'/\\r}"
    printf '"%s"' "$result"
  fi
}

# ── Fingerprint helper ──────────────────────────────────────────────────────

fingerprint_secret() {
  local value="$1"
  if [[ -z "$value" ]]; then
    echo ""
    return
  fi
  if command -v sha256sum &>/dev/null; then
    printf '%s' "$value" | sha256sum | awk '{print "sha256:" substr($1,1,8)}'
  elif command -v shasum &>/dev/null; then
    printf '%s' "$value" | LC_ALL=C LANG=C shasum -a 256 2>/dev/null | awk '{print "sha256:" substr($1,1,8)}'
  else
    echo "present"
  fi
}

# ── Safe env reader ─────────────────────────────────────────────────────────

# Read a single value from an env file without sourcing it.
# Does NOT execute shell commands in the file.
# Supports: KEY=value, KEY="value", KEY='value'
# Does NOT support: variable expansion ($OTHER), command substitution, multi-line.

read_env_value() {
  local file="$1"
  local key="$2"
  [[ -f "$file" ]] || return 0
  awk -v key="$key" '
    /^[[:space:]]*#/ { next }
    /^[[:space:]]*$/ { next }
    {
      line=$0
      sub(/^[[:space:]]*/, "", line)
      if (line ~ "^" key "=") {
        sub("^" key "=", "", line)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", line)
        # Strip surrounding quotes
        if ((substr(line,1,1) == "\"" && substr(line,length(line),1) == "\"") ||
            (substr(line,1,1) == "\x27" && substr(line,length(line),1) == "\x27")) {
          line=substr(line,2,length(line)-2)
        }
        print line
        exit
      }
    }
  ' "$file"
}

# ── Repo resolution ─────────────────────────────────────────────────────────

resolve_repo_dir() {
  if [[ -n "$REPO_DIR" ]]; then
    return
  fi

  if [[ -n "${NANOBK_REPO_DIR:-}" ]]; then
    REPO_DIR="$NANOBK_REPO_DIR"
    return
  fi

  local config_file="${CONFIG_DIR}/config.env"
  if [[ -f "$config_file" ]]; then
    local repo_from_config
    repo_from_config=$(grep -E '^NANOBK_REPO_DIR=' "$config_file" 2>/dev/null | head -1 | cut -d= -f2- | tr -d '"' || true)
    if [[ -n "$repo_from_config" ]] && [[ -d "$repo_from_config" ]]; then
      REPO_DIR="$repo_from_config"
      return
    fi
  fi

  for candidate in "/opt/NanoBK-Proxy-Suite" "${HOME}/NanoBK-Proxy-Suite"; do
    if [[ -d "$candidate" ]] && [[ -f "$candidate/installer/install.sh" ]]; then
      REPO_DIR="$candidate"
      return
    fi
  done

  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -f "${script_dir}/../installer/install.sh" ]]; then
    REPO_DIR="$(cd "${script_dir}/.." && pwd)"
    return
  fi

  die "无法定位 NanoBK 仓库。
请设置:
  export NANOBK_REPO_DIR=/path/to/NanoBK-Proxy-Suite
或重新运行 bootstrap:
  bash <(curl -fsSL https://raw.githubusercontent.com/kairkiss/NanoBK-Proxy-Suite/main/installer/bootstrap.sh)"
}

# ── Safe command runner ─────────────────────────────────────────────────────

print_cmd() {
  printf "  ${CYAN}\$${NC} "
  printf "%q " "$@"
  printf "\n"
}

run_script() {
  local desc="$1"
  shift
  local cmd=("$@")

  log "$desc"
  print_cmd "${cmd[@]}"

  if [[ "$DRY_RUN" == "1" ]]; then
    echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
    return 0
  fi

  "${cmd[@]}"
}

# ── Commands ────────────────────────────────────────────────────────────────

cmd_version() {
  echo "nanobk ${NANOBK_VERSION}"
}

# ── CLI UI helpers ──────────────────────────────────────────────────────────

# Returns 0 if both stdin and stdout are TTYs.
# Test-only override: NANOBK_TEST_FORCE_TTY=1 bypasses TTY check.
is_interactive_tty() {
  [[ "${NANOBK_TEST_FORCE_TTY:-}" == "1" ]] && return 0
  [[ -t 0 ]] && [[ -t 1 ]]
}

# UI primitives — no external deps, no Python, no curses
ui_title() {
  echo -e "${BOLD}$*${NC}"
}

ui_section() {
  echo ""
  echo -e "  ${BOLD}$*${NC}"
}

ui_hint() {
  echo -e "  ${CYAN}$*${NC}"
}

ui_success() {
  echo -e "  ${GREEN}$*${NC}"
}

ui_warning() {
  echo -e "  ${YELLOW}$*${NC}"
}

ui_safe_action() {
  echo -e "  ${GREEN}[safe]${NC} $*"
}

ui_explicit_action() {
  echo -e "  ${YELLOW}[explicit]${NC} $*"
}

ui_advanced_action() {
  echo -e "  ${CYAN}[advanced]${NC} $*"
}

console_pause() {
  is_interactive_tty || return 0
  echo ""
  printf "  Press Enter to return to menu…"
  read -r _ || true
}

# ── Console helpers ─────────────────────────────────────────────────────────

print_console_header() {
  echo ""
  echo -e "${BOLD}╔══════════════════════════════════════════════════════════╗${NC}"
  echo -e "${BOLD}║                    NanoBK Proxy Suite                   ║${NC}"
  echo -e "${BOLD}║              VPS Proxy Automation Console               ║${NC}"
  echo -e "${BOLD}╚══════════════════════════════════════════════════════════╝${NC}"
  echo ""
  echo "  NanoBK v${NANOBK_VERSION}"
  echo "  Safe by default · deployment requires explicit confirmation"
  echo ""
}

print_console_menu() {
  echo "  1) Status"
  echo "  2) Doctor / diagnostics"
  echo "  3) New deployment / Full Wizard"
  echo "  4) Cloudflare DNS tools"
  echo "  5) Export protocol links"
  echo "  6) Rotate keys"
  echo "  7) Install / repair CLI"
  echo "  8) Advanced commands / full help"
  echo "  9) Exit"
  echo ""
}

# DNS submenu — guidance-first (does not auto-run commands)
console_dns_submenu() {
  ui_section "Cloudflare DNS Tools"
  ui_hint "Read-only guidance in this console"
  echo ""
  echo "  1) Preview DNS plan"
  echo "  2) Validate DNS profile"
  echo "  3) Read-only check (--check)"
  echo "  4) DNS readiness report"
  echo "  5) Back"
  echo ""
  local choice
  read -rp "  Select [1-5]: " choice || { echo ""; return; }
  case "$choice" in
    1)
      echo ""
      ui_safe_action "Preview DNS plan (dry-run, no mutation):"
      echo ""
      echo "    nanobk cf dns plan --profile /etc/nanobk/cloudflare-dns-profile.json"
      echo ""
      echo "  Or with direct arguments:"
      echo ""
      echo "    nanobk cf dns plan --zone example.com --node proxy --ipv4 YOUR_VPS_IPV4"
      console_pause
      ;;
    2)
      echo ""
      ui_safe_action "Validate DNS profile (read-only):"
      echo ""
      echo "    nanobk cf dns validate-profile --profile /etc/nanobk/cloudflare-dns-profile.json"
      console_pause
      ;;
    3)
      echo ""
      ui_safe_action "Read-only check (GET-only, no DNS mutation):"
      echo ""
      echo "    nanobk cf dns apply --profile /etc/nanobk/cloudflare-dns-profile.json \\"
      echo "      --api-env /etc/nanobk/cloudflare-api.env --check"
      console_pause
      ;;
    4)
      echo ""
      ui_safe_action "DNS readiness report (read-only):"
      echo ""
      echo "    nanobk cf dns readiness \\"
      echo "      --api-env /etc/nanobk/cloudflare-api.env \\"
      echo "      --profile /etc/nanobk/cloudflare-dns-profile.json"
      console_pause
      ;;
    5|"")
      return
      ;;
    *)
      echo "  Invalid input. Please enter 1-5."
      console_pause
      ;;
  esac
}

# Console loop — interactive menu
console_loop() {
  while true; do
    print_console_menu
    local choice
    read -rp "  Select [1-9]: " choice || { echo ""; break; }
    case "$choice" in
      1)
        ui_section "Status"
        ui_safe_action "Read-only status view"
        echo ""
        cmd_status || true
        console_pause
        ;;
      2)
        ui_section "Doctor / Diagnostics"
        ui_safe_action "Read-only diagnostics"
        echo ""
        cmd_doctor || true
        console_pause
        ;;
      3)
        ui_section "New Deployment / Full Wizard"
        ui_explicit_action "Explicit deployment flow"
        echo ""
        echo "  This starts the legacy Full Wizard."
        echo "  Command: nanobk install --mode full"
        echo ""
        echo "    1) Start Full Wizard"
        echo "    2) Back"
        echo ""
        local deploy_choice
        read -rp "  Select [1-2]: " deploy_choice || { echo ""; continue; }
        case "$deploy_choice" in
          1)
            echo ""
            echo "  Starting Full Wizard..."
            echo ""
            cmd_install --mode full || true
            ;;
          2|"")
            continue
            ;;
          *)
            echo "  Invalid input. Returning to menu."
            ;;
        esac
        ;;
      4)
        console_dns_submenu
        ;;
      5)
        ui_section "Export Protocol Links"
        ui_warning "Sensitive output; run explicit export command"
        echo ""
        echo "  Export commands:"
        echo "    nanobk export link hy2"
        echo "    nanobk export link tuic"
        echo "    nanobk export link reality"
        echo "    nanobk export link trojan"
        echo "    nanobk export links"
        console_pause
        ;;
      6)
        ui_section "Rotate Keys"
        ui_explicit_action "Credential-changing operation; run explicit command"
        echo ""
        echo "  Rotate commands:"
        echo "    nanobk rotate all"
        echo "    nanobk rotate hy2"
        echo "    nanobk rotate tuic"
        echo "    nanobk rotate reality"
        echo "    nanobk rotate trojan"
        echo ""
        echo "  Run these commands explicitly when ready."
        console_pause
        ;;
      7)
        ui_section "Install / Repair CLI"
        ui_safe_action "Install nanobk symlink to /usr/local/bin"
        echo ""
        cmd_install_cli || true
        console_pause
        ;;
      8)
        ui_section "Advanced Commands / Full Help"
        ui_advanced_action "Full CLI reference"
        echo ""
        cmd_help
        console_pause
        ;;
      9|"")
        echo ""
        echo "  Goodbye."
        echo ""
        break
        ;;
      *)
        echo "  Invalid input. Please enter 1-9."
        console_pause
        ;;
    esac
  done
}

# Main console command
cmd_console() {
  if is_interactive_tty; then
    print_console_header
    console_loop
  else
    # Non-TTY: show safe entry text and exit
    cmd_entry
  fi
}

cmd_entry() {
  # TTY: open interactive console
  if is_interactive_tty; then
    print_console_header
    console_loop
    return
  fi

  # Non-TTY: safe non-interactive entry screen
  echo ""
  echo -e "${BOLD}NanoBK Proxy Suite${NC} v${NANOBK_VERSION}"
  echo ""
  echo "  NanoBK is ready."
  echo ""
  echo "  Start here:"
  echo "    nanobk status             Show current status"
  echo "    nanobk doctor             Run environment diagnostics"
  echo ""
  echo "  Deployment (explicit):"
  echo "    nanobk install --mode full        Full Wizard (VPS + Cloudflare + Bot + Web)"
  echo "    nanobk install --mode vps         VPS only"
  echo "    nanobk install --mode cloudflare  Cloudflare only"
  echo "    nanobk install --mode bot         Telegram Bot only"
  echo "    nanobk install --mode web         Web Panel only"
  echo ""
  echo "  DNS (Cloudflare):"
  echo "    nanobk cf dns plan                Preview DNS plan"
  echo "    nanobk cf dns validate-profile    Validate DNS profile"
  echo "    nanobk cf dns apply --check       Check existing records (read-only)"
  echo "    nanobk --help                     See advanced DNS apply options"
  echo ""
  echo "  Management:"
  echo "    nanobk rotate <protocol>          Rotate keys"
  echo "    nanobk export link <protocol>     Export protocol link"
  echo "    nanobk export links               Export all links"
  echo "    nanobk test                       Run local tests"
  echo "    nanobk install-cli                Install nanobk to /usr/local/bin"
  echo "    nanobk console                    Interactive console (TTY required)"
  echo "    nanobk --help                     Full help"
  echo ""
  echo "  Deployment is not started automatically."
  echo "  Use explicit commands above to deploy."
  echo ""
}

cmd_help() {
  cat <<EOF
NanoBK Proxy Suite — Unified CLI v${NANOBK_VERSION}

用法: nanobk [全局选项] <命令> [命令选项...]

全局选项:
  --repo-dir PATH    指定仓库根目录
  --dry-run          只打印命令，不执行
  --json             JSON 输出（部分命令支持）
  --help             显示帮助
  --version          显示版本

命令:
  status [--config-dir PATH]  显示 VPS / Cloudflare / 聚合器状态
  doctor                      运行环境诊断
  console                     交互式控制台（需要 TTY）
  install [args...]           启动交互式安装器
  install-cli                 安装 nanobk 到 /usr/local/bin
  cf deploy [args...]         部署 Cloudflare Workers
  cf verify [nanok|nanob]     刷新 Cloudflare 订阅验证状态
  cf install-admin-env        安装 rotate sync admin env 到 /root
  cf dns plan [options...]    Cloudflare DNS 干跑计划（不创建 DNS）
  cf dns validate-profile     验证 DNS 配置文件
  cf dns apply [options...]   应用 DNS 记录到 Cloudflare（需要 --yes）
  cf dns readiness [--api-env PATH] [--profile PATH]  只读 DNS 就绪检查 [--json]
  cf dns target preview --zone DOMAIN --ip-fixture PATH  只读 DNS 目标预览 [--json]
  cf dns availability check --zone DOMAIN --node NODE --api-env PATH  只读子域名可用性检查 [--json]
  cf dns availability summary --zone DOMAIN --api-env PATH [--nodes proxy,web]  多主机可用性摘要 [--json]
  cf dns report --zone DOMAIN --api-env PATH --ip-fixture PATH  综合 DNS 准备报告 [--json]
  cf dns profile preview --zone DOMAIN --node NODE --ipv4 VALUE  DNS 配置预览 [--json]
  cf dns profile generate --zone DOMAIN --node NODE --ipv4 VALUE --output PATH --yes  生成临时 DNS 配置 [--json]
  cf zones list --api-env PATH  只读列出 Cloudflare zones [--json]
  vps ip detect               只读 VPS IP 候选检测 [--json]
  rotate <protocol> [args.]  换密钥: all|hy2|tuic|reality|trojan
  export link <protocol>     导出单个协议链接: hy2|tuic|reality|trojan
  export links               导出所有协议链接
  test [--all]                运行本地测试
  version                     显示版本

--dry-run 可以放在全局位置或命令后:
  nanobk --dry-run test
  nanobk test --dry-run

示例:
  nanobk status
  nanobk --json status
  nanobk doctor
  nanobk install-cli
  nanobk install --mode commands
  nanobk cf deploy --dry-run --create-kv --route-url https://nanok.example.com
  nanobk rotate all --skip-cloudflare
  nanobk export link hy2
  nanobk export link reality --profile /path/to/profile.json
  nanobk export links --json
  nanobk test --all

CLI 安装:
  sudo nanobk install-cli
  # 或手动: sudo ln -sf "\$(pwd)/bin/nanobk" /usr/local/bin/nanobk
EOF
}

# ── install-cli ─────────────────────────────────────────────────────────────

cmd_install_cli() {
  local target="/usr/local/bin/nanobk"
  local force=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --target) target="$2"; shift ;;
      --force)  force=1 ;;
      --dry-run) DRY_RUN=1 ;;
      *) die "Unknown install-cli option: $1" ;;
    esac
    shift
  done

  local source_path="${REPO_DIR}/bin/nanobk"

  if [[ ! -f "$source_path" ]]; then
    die "Source not found: ${source_path}"
  fi

  # Check target existence (safe checks, no writes)
  if [[ -e "$target" ]] || [[ -L "$target" ]]; then
    if [[ -L "$target" ]]; then
      local current_link
      current_link=$(readlink "$target" 2>/dev/null || echo "")
      if [[ "$current_link" == "$source_path" ]]; then
        ok "nanobk 已安装: ${target} → ${source_path}"
        return 0
      fi
      # Different symlink
      if [[ "$force" != "1" ]]; then
        die "目标已存在，指向其他位置:
  ${target} → ${current_link}
  期望: ${source_path}
  使用 --force 覆盖。"
      fi
      warn "覆盖已有 symlink (--force): ${target} → ${current_link}"
    else
      # Regular file
      if [[ "$force" != "1" ]]; then
        die "目标已存在（非 symlink），不会覆盖:
  ${target}
  使用 --force 覆盖。"
      fi
      warn "覆盖已有文件 (--force): ${target}"
    fi
  fi

  # Dry-run: print what would happen, skip permission check
  if [[ "$DRY_RUN" == "1" ]]; then
    log "安装 nanobk CLI:"
    print_cmd ln -sf "$source_path" "$target"
    echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
    return 0
  fi

  # Check if target directory needs root
  local target_dir
  target_dir=$(dirname "$target")
  if [[ ! -w "$target_dir" ]] && [[ $EUID -ne 0 ]]; then
    echo ""
    warn "目标目录需要 root 权限: ${target_dir}"
    echo ""
    echo "  推荐命令:"
    echo "    sudo ln -sf \"${source_path}\" \"${target}\""
    echo ""
    die "请使用 sudo 重试。"
  fi

  log "安装 nanobk CLI:"
  print_cmd ln -sf "$source_path" "$target"

  ln -sf "$source_path" "$target"
  ok "已安装: ${target} → ${source_path}"
  echo ""
  echo "  现在可以直接使用: nanobk status"
}

# ── status ──────────────────────────────────────────────────────────────────

cmd_status() {
  local config_dir="$CONFIG_DIR"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --config-dir) config_dir="$2"; shift ;;
      --dry-run) ;;
      *) die "Unknown status option: $1" ;;
    esac
    shift
  done

  local config_file="${config_dir}/config.env"
  local profile_file="${config_dir}/profile.current.json"
  local secrets_file="${config_dir}/secrets.private.env"

  # Load VPS config
  local domain="" vps_ip="" geo="" reality_sname=""
  local hy2_service="hysteria-server.service"
  local tuic_service="tuic-v5-9443.service"
  local reality_service="xray-reality-8443.service"
  local trojan_service="xray-trojan-2443.service"

  local config_exists=0
  if [[ -f "$config_file" ]]; then
    config_exists=1
    # shellcheck source=/dev/null
    source "$config_file"
    domain="${NANOBK_DOMAIN:-}"
    vps_ip="${NANOBK_VPS_IP:-}"
    geo="${NANOBK_GEO_LABEL:-}"
    reality_sname="${REALITY_SERVERNAME:-}"
  fi

  # Check profile
  local profile_exists=0 profile_updated=""
  local has_hy2=0 has_tuic=0 has_reality=0 has_trojan=0

  if [[ -f "$profile_file" ]]; then
    profile_exists=1
    if command -v jq &>/dev/null; then
      profile_updated=$(jq -r '.updatedAt // empty' "$profile_file" 2>/dev/null || echo "")
      jq -e '.hy2' "$profile_file" >/dev/null 2>&1 && has_hy2=1
      jq -e '.tuic' "$profile_file" >/dev/null 2>&1 && has_tuic=1
      jq -e '.reality' "$profile_file" >/dev/null 2>&1 && has_reality=1
      jq -e '.trojan' "$profile_file" >/dev/null 2>&1 && has_trojan=1
    elif command -v python3 &>/dev/null; then
      profile_updated=$(python3 -c "import json; d=json.load(open('$profile_file')); print(d.get('updatedAt',''))" 2>/dev/null || echo "")
      python3 -c "import json; d=json.load(open('$profile_file')); [d[k] for k in ('hy2','tuic','reality','trojan')]" 2>/dev/null && {
        has_hy2=1; has_tuic=1; has_reality=1; has_trojan=1
      }
    fi
  fi

  # Check services
  local svc_hy2="unknown" svc_tuic="unknown" svc_reality="unknown" svc_trojan="unknown"
  if command -v systemctl &>/dev/null; then
    svc_hy2=$(systemctl is-active "$hy2_service" 2>/dev/null || echo "inactive")
    svc_tuic=$(systemctl is-active "$tuic_service" 2>/dev/null || echo "inactive")
    svc_reality=$(systemctl is-active "$reality_service" 2>/dev/null || echo "inactive")
    svc_trojan=$(systemctl is-active "$trojan_service" 2>/dev/null || echo "inactive")
  fi

  # Check VPS secrets
  local secrets_exists=0 secrets_mode="missing"
  if [[ -f "$secrets_file" ]]; then
    secrets_exists=1
    secrets_mode=$(stat -c '%a' "$secrets_file" 2>/dev/null || stat -f '%Lp' "$secrets_file" 2>/dev/null || echo "unknown")
  fi

  # ── Cloudflare nanok env ──
  local cf_nanok_env="missing"
  local cf_nanok_worker="" cf_nanok_url="" cf_nanok_sub_path="" cf_nanok_deploy=""
  local cf_nanok_profile_upload="" cf_nanok_verify=""
  local cf_nanok_sub_token="" cf_nanok_admin_token="" cf_nanok_kv=""
  local cf_admin_env_exists="false"
  local cf_sub_token_fp="" cf_admin_token_fp=""

  # Try to find .cloudflare.local.env
  local cf_env_file=""
  for candidate in \
    "${REPO_DIR}/.cloudflare.local.env" \
    "${config_dir}/cloudflare.local.env" \
    "/root/.nanok-cf-admin.env"; do
    if [[ -f "$candidate" ]]; then
      cf_env_file="$candidate"
      break
    fi
  done

  if [[ -n "$cf_env_file" ]] && [[ -f "$cf_env_file" ]]; then
    cf_nanok_env="present"
    cf_nanok_worker=$(read_env_value "$cf_env_file" "NANOK_WORKER_NAME")
    cf_nanok_url=$(read_env_value "$cf_env_file" "NANOK_ROUTE_URL")
    cf_nanok_sub_path=$(read_env_value "$cf_env_file" "SUB_PATH")
    cf_nanok_deploy=$(read_env_value "$cf_env_file" "NANOBK_DEPLOY_STATUS")
    [[ -z "$cf_nanok_deploy" ]] && cf_nanok_deploy="unknown"
    cf_nanok_profile_upload=$(read_env_value "$cf_env_file" "NANOBK_PROFILE_UPLOAD_STATUS")
    [[ -z "$cf_nanok_profile_upload" ]] && cf_nanok_profile_upload="unknown"
    cf_nanok_verify=$(read_env_value "$cf_env_file" "NANOBK_VERIFY_STATUS")
    [[ -z "$cf_nanok_verify" ]] && cf_nanok_verify="unknown"
    cf_nanok_kv=$(read_env_value "$cf_env_file" "SUB_STORE_KV_NAMESPACE_ID")

    local cf_sub_token cf_admin_token
    cf_sub_token=$(read_env_value "$cf_env_file" "SUB_TOKEN")
    if [[ -n "$cf_sub_token" ]]; then
      cf_nanok_sub_token="present"
      cf_sub_token_fp=$(fingerprint_secret "$cf_sub_token")
    fi
    cf_admin_token=$(read_env_value "$cf_env_file" "ADMIN_TOKEN")
    if [[ -n "$cf_admin_token" ]]; then
      cf_nanok_admin_token="present"
      cf_admin_token_fp=$(fingerprint_secret "$cf_admin_token")
    fi
  fi

  # Check admin env separately (test-only hook for mock path isolation)
  local status_admin_env_path="${NANOBK_STATUS_TEST_ADMIN_ENV_PATH:-/root/.nanok-cf-admin.env}"
  if [[ -f "$status_admin_env_path" ]]; then
    cf_admin_env_exists="true"
  fi

  # ── Cloudflare nanob env ──
  local cf_nanob_env="missing"
  local cf_nanob_worker="" cf_nanob_url="" cf_nanob_path=""
  local cf_nanob_deploy="" cf_nanob_verify=""
  local cf_nanob_token="" cf_nanob_token_fp=""
  local cf_nanob_geo_kv="" cf_nanob_edge_host=""

  local nanob_env_file=""
  for candidate in \
    "${REPO_DIR}/.nanob.local.env" \
    "${config_dir}/nanob.local.env"; do
    if [[ -f "$candidate" ]]; then
      nanob_env_file="$candidate"
      break
    fi
  done

  if [[ -n "$nanob_env_file" ]] && [[ -f "$nanob_env_file" ]]; then
    cf_nanob_env="present"
    cf_nanob_worker=$(read_env_value "$nanob_env_file" "NANOB_WORKER_NAME")
    cf_nanob_url=$(read_env_value "$nanob_env_file" "NANOB_ROUTE_URL")
    cf_nanob_path=$(read_env_value "$nanob_env_file" "NANOB_PATH")
    cf_nanob_deploy=$(read_env_value "$nanob_env_file" "NANOB_DEPLOY_STATUS")
    [[ -z "$cf_nanob_deploy" ]] && cf_nanob_deploy="unknown"
    cf_nanob_verify=$(read_env_value "$nanob_env_file" "NANOB_VERIFY_STATUS")
    [[ -z "$cf_nanob_verify" ]] && cf_nanob_verify="unknown"
    cf_nanob_geo_kv=$(read_env_value "$nanob_env_file" "NANOB_GEO_KV_NAMESPACE_ID")
    cf_nanob_edge_host=$(read_env_value "$nanob_env_file" "EDGE_HOST")

    local cf_nanob_token_val
    cf_nanob_token_val=$(read_env_value "$nanob_env_file" "NANOB_TOKEN")
    if [[ -n "$cf_nanob_token_val" ]]; then
      cf_nanob_token="present"
      cf_nanob_token_fp=$(fingerprint_secret "$cf_nanob_token_val")
    fi
  fi

  # ── Compute ok and warnings ──
  local status_ok="true"
  local warnings=()

  if [[ "$config_exists" != "1" ]]; then
    status_ok="false"
    warnings+=("config.env missing")
  fi
  if [[ "$profile_exists" != "1" ]]; then
    status_ok="false"
    warnings+=("profile.current.json missing")
  elif [[ "$has_hy2" != "1" || "$has_tuic" != "1" || "$has_reality" != "1" || "$has_trojan" != "1" ]]; then
    status_ok="false"
    warnings+=("profile incomplete (missing protocol sections)")
  fi
  if [[ "$secrets_exists" == "1" && "$secrets_mode" != "600" ]]; then
    warnings+=("secrets.private.env mode ${secrets_mode} (should be 600)")
  fi
  if [[ "$cf_nanok_env" == "missing" ]]; then
    warnings+=("cloudflare local env missing")
  fi

  # ── Output ──
  if [[ "$JSON_OUT" == "1" ]]; then
    local secrets_mode_ok="true"
    [[ "$secrets_mode" != "600" ]] && secrets_mode_ok="false"

    local warnings_json="["
    local first=1
    for w in "${warnings[@]+"${warnings[@]}"}"; do
      [[ $first -eq 1 ]] && first=0 || warnings_json+=","
      warnings_json+="$(json_escape "$w")"
    done
    warnings_json+="]"

    cat <<EOF
{
  "ok": ${status_ok},
  "configDir": $(json_escape "${config_dir}"),
  "domain": $(json_escape "${domain}"),
  "vpsIp": $(json_escape "${vps_ip}"),
  "geo": $(json_escape "${geo}"),
  "profile": {
    "exists": $([ "$profile_exists" == "1" ] && echo "true" || echo "false"),
    "updatedAt": $(json_escape "${profile_updated}"),
    "hy2": $([ "$has_hy2" == "1" ] && echo "true" || echo "false"),
    "tuic": $([ "$has_tuic" == "1" ] && echo "true" || echo "false"),
    "reality": $([ "$has_reality" == "1" ] && echo "true" || echo "false"),
    "trojan": $([ "$has_trojan" == "1" ] && echo "true" || echo "false")
  },
  "services": {
    "hy2": $(json_escape "${svc_hy2}"),
    "tuic": $(json_escape "${svc_tuic}"),
    "reality": $(json_escape "${svc_reality}"),
    "trojan": $(json_escape "${svc_trojan}")
  },
  "security": {
    "secretsExists": $([ "$secrets_exists" == "1" ] && echo "true" || echo "false"),
    "secretsMode": $(json_escape "${secrets_mode}"),
    "secretsModeOk": ${secrets_mode_ok}
  },
  "cloudflare": {
    "nanok": {
      "envExists": $([ "$cf_nanok_env" == "present" ] && echo "true" || echo "false"),
      "workerName": $(json_escape "${cf_nanok_worker}"),
      "routeUrl": $(json_escape "${cf_nanok_url}"),
      "subPath": $(json_escape "${cf_nanok_sub_path}"),
      "deployStatus": $(json_escape "${cf_nanok_deploy}"),
      "profileUploadStatus": $(json_escape "${cf_nanok_profile_upload}"),
      "verifyStatus": $(json_escape "${cf_nanok_verify}"),
      "subTokenPresent": $([ "$cf_nanok_sub_token" == "present" ] && echo "true" || echo "false"),
      "subTokenFingerprint": $(json_escape "${cf_sub_token_fp}"),
      "adminTokenPresent": $([ "$cf_nanok_admin_token" == "present" ] && echo "true" || echo "false"),
      "adminTokenFingerprint": $(json_escape "${cf_admin_token_fp}"),
      "kvNamespacePresent": $([ -n "$cf_nanok_kv" ] && echo "true" || echo "false"),
      "adminEnvExists": ${cf_admin_env_exists}
    },
    "nanob": {
      "envExists": $([ "$cf_nanob_env" == "present" ] && echo "true" || echo "false"),
      "workerName": $(json_escape "${cf_nanob_worker}"),
      "routeUrl": $(json_escape "${cf_nanob_url}"),
      "path": $(json_escape "${cf_nanob_path}"),
      "deployStatus": $(json_escape "${cf_nanob_deploy}"),
      "verifyStatus": $(json_escape "${cf_nanob_verify}"),
      "tokenPresent": $([ "$cf_nanob_token" == "present" ] && echo "true" || echo "false"),
      "tokenFingerprint": $(json_escape "${cf_nanob_token_fp}"),
      "geoKvNamespacePresent": $([ -n "$cf_nanob_geo_kv" ] && echo "true" || echo "false"),
      "edgeHostConfigured": $([ -n "$cf_nanob_edge_host" ] && echo "true" || echo "false")
    }
  },
  "warnings": ${warnings_json}
}
EOF
  else
    echo ""
    echo -e "${BOLD}NanoBK Status${NC}"
    echo ""
    echo "  Config:"
    echo "    config-dir:  ${config_dir}"
    echo "    domain:      ${domain:-<not set>}"
    echo "    vps-ip:      ${vps_ip:-<not set>}"
    echo "    geo:         ${geo:-<not set>}"
    echo ""
    echo "  Profile:"
    if [[ "$profile_exists" == "1" ]]; then
      echo "    updatedAt:   ${profile_updated:-<unknown>}"
      echo "    hy2:         $([ "$has_hy2" == "1" ] && echo "present" || echo "missing")"
      echo "    tuic:        $([ "$has_tuic" == "1" ] && echo "present" || echo "missing")"
      echo "    reality:     $([ "$has_reality" == "1" ] && echo "present" || echo "missing")"
      echo "    trojan:      $([ "$has_trojan" == "1" ] && echo "present" || echo "missing")"
    else
      echo "    <profile not found>"
    fi
    echo ""
    echo "  Services:"
    echo "    ${hy2_service}:      ${svc_hy2}"
    echo "    ${tuic_service}:     ${svc_tuic}"
    echo "    ${reality_service}:  ${svc_reality}"
    echo "    ${trojan_service}:   ${svc_trojan}"
    echo ""
    echo "  Security:"
    if [[ "$secrets_exists" == "1" ]]; then
      local mode_label="${secrets_mode}"
      [[ "$secrets_mode" != "600" ]] && mode_label="${secrets_mode} (should be 600)"
      echo "    secrets.private.env: mode ${mode_label}"
    else
      echo "    secrets.private.env: missing"
    fi
    echo ""
    echo "  Cloudflare:"
    echo "    nanok env:       ${cf_nanok_env}"
    if [[ "$cf_nanok_env" == "present" ]]; then
      echo "    nanok worker:    ${cf_nanok_worker:-<not set>}"
      echo "    nanok url:       ${cf_nanok_url:-<not set>}"
      echo "    nanok deploy:    ${cf_nanok_deploy}"
      echo "    profile upload:  ${cf_nanok_profile_upload}"
      echo "    verify:          ${cf_nanok_verify}"
      echo "    sub token:       ${cf_nanok_sub_token:-missing}${cf_nanok_sub_token:+ fingerprint=${cf_sub_token_fp}}"
      echo "    admin token:     ${cf_nanok_admin_token:-missing}${cf_nanok_admin_token:+ fingerprint=${cf_admin_token_fp}}"
      echo "    kv namespace:    $([ -n "$cf_nanok_kv" ] && echo "present" || echo "missing")"
    fi
    echo ""
    echo "  Aggregator:"
    if [[ "$cf_nanob_env" == "present" ]]; then
      echo "    nanob env:       ${cf_nanob_env}"
      echo "    nanob worker:    ${cf_nanob_worker:-<not set>}"
      echo "    nanob url:       ${cf_nanob_url:-<not set>}"
      echo "    nanob deploy:    ${cf_nanob_deploy}"
      echo "    nanob verify:    ${cf_nanob_verify}"
      echo "    nanob token:     ${cf_nanob_token:-missing}${cf_nanob_token:+ fingerprint=${cf_nanob_token_fp}}"
      echo "    geo kv:          $([ -n "$cf_nanob_geo_kv" ] && echo "present" || echo "missing")"
      echo "    edge host:       $([ -n "$cf_nanob_edge_host" ] && echo "configured" || echo "disabled")"
    else
      echo "    nanob: not configured"
    fi
    if [[ ${#warnings[@]} -gt 0 ]]; then
      echo ""
      echo "  Warnings:"
      for w in "${warnings[@]+"${warnings[@]}"}"; do
        echo "    - ${w}"
      done
    fi
    echo ""
  fi
}

# ── doctor ──────────────────────────────────────────────────────────────────

cmd_doctor() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run) DRY_RUN=1 ;;
      --json)    JSON_OUT=1 ;;
      *) die "Unknown doctor option: $1" ;;
    esac
    shift
  done

  if [[ "$JSON_OUT" == "1" ]]; then
    echo '{"ok":true,"command":"doctor","note":"JSON doctor output is planned for v1.x; raw output is text-only in v0.8"}'
    echo ""
  fi
  run_script "运行环境诊断" bash "$REPO_DIR/installer/doctor.sh" || {
    local exit_code=$?
    warn "doctor 退出码: ${exit_code}（有错误或警告）"
    return $exit_code
  }
}

# ── install ─────────────────────────────────────────────────────────────────

cmd_install() {
  local cmd=(bash "$REPO_DIR/installer/install.sh" --repo-dir "$REPO_DIR")
  local has_dry_run=0
  for arg in "$@"; do
    [[ "$arg" == "--dry-run" ]] && has_dry_run=1
  done
  [[ "$DRY_RUN" == "1" && "$has_dry_run" == "0" ]] && cmd+=(--dry-run)
  cmd+=("$@")

  run_script "启动安装器" "${cmd[@]}"
}

# ── cf deploy ───────────────────────────────────────────────────────────────

cmd_cf_deploy() {
  local cmd=(bash "$REPO_DIR/installer/install-cloudflare.sh")
  local has_dry_run=0
  for arg in "$@"; do
    [[ "$arg" == "--dry-run" ]] && has_dry_run=1
  done
  [[ "$DRY_RUN" == "1" && "$has_dry_run" == "0" ]] && cmd+=(--dry-run)
  cmd+=("$@")

  run_script "部署 Cloudflare Workers" "${cmd[@]}"
}

# ── cf verify ───────────────────────────────────────────────────────────────

cmd_cf_verify() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    nanok)
      local cmd=(bash "$REPO_DIR/installer/install-cloudflare.sh" --verify-nanok-only)
      [[ "$DRY_RUN" == "1" ]] && cmd+=(--dry-run)
      run_script "验证 nanok 订阅" "${cmd[@]}"
      ;;
    nanob)
      local cmd=(bash "$REPO_DIR/installer/install-cloudflare.sh" --verify-nanob-only)
      [[ "$DRY_RUN" == "1" ]] && cmd+=(--dry-run)
      run_script "验证 nanob 订阅" "${cmd[@]}"
      ;;
    "")
      # Verify both
      cmd_cf_verify nanok
      cmd_cf_verify nanob
      ;;
    *)
      die "Usage: nanobk cf verify [nanok|nanob]"
      ;;
  esac
}

cmd_cf_install_admin_env() {
  local local_env="${REPO_DIR}/.cloudflare.local.env"
  local target="/root/.nanok-cf-admin.env"

  if [[ ! -f "$local_env" ]]; then
    die "Cloudflare local env not found: ${local_env}\nRun: bash installer/install-cloudflare.sh first"
  fi

  local adm_token adm_current adm_update
  adm_token=$(read_env_value "$local_env" "ADMIN_TOKEN" 2>/dev/null || echo "")
  adm_current=$(read_env_value "$local_env" "ADMIN_CURRENT_URL" 2>/dev/null || echo "")
  adm_update=$(read_env_value "$local_env" "ADMIN_UPDATE_URL" 2>/dev/null || echo "")

  if [[ -z "$adm_token" ]] || [[ -z "$adm_current" ]] || [[ -z "$adm_update" ]]; then
    die "Cloudflare local env is missing required fields (ADMIN_TOKEN, ADMIN_CURRENT_URL, ADMIN_UPDATE_URL)"
  fi

  # Write to temp file (never put token in sudo argv)
  local tmp_admin
  tmp_admin=$(mktemp)
  chmod 600 "$tmp_admin"
  cat > "$tmp_admin" <<ENVEOF
ADMIN_TOKEN="${adm_token}"
ADMIN_CURRENT_URL="${adm_current}"
ADMIN_UPDATE_URL="${adm_update}"
ENVEOF

  if [[ $EUID -eq 0 ]]; then
    install -m 600 "$tmp_admin" "$target"
    rm -f "$tmp_admin"
    ok "Admin env installed: ${target} (mode 600)"
  else
    if command -v sudo &>/dev/null; then
      sudo install -m 600 "$tmp_admin" "$target" 2>/dev/null && {
        rm -f "$tmp_admin"
        ok "Admin env installed via sudo: ${target} (mode 600)"
      } || {
        rm -f "$tmp_admin"
        die "无法写入 ${target}，需要 sudo 权限。"
      }
    else
      rm -f "$tmp_admin"
      die "无法写入 ${target}，需要 sudo 权限。"
    fi
  fi
}

# ── cf dns ────────────────────────────────────────────────────────────────

cmd_cf_dns() {
  local dns_sub="${1:-}"
  shift 2>/dev/null || true

  local dns_script="${REPO_DIR}/lib/nanobk_cf_dns.py"
  [[ -f "$dns_script" ]] || die "DNS plan script not found: ${dns_script}"

  case "$dns_sub" in
    plan)
      local args=(python3 "$dns_script" plan)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --profile)
            [[ $# -ge 2 ]] || die "cf dns plan: --profile needs a path argument"
            args+=("$1" "$2"); shift 2 ;;
          --zone)
            [[ $# -ge 2 ]] || die "cf dns plan: --zone needs a value"
            args+=("$1" "$2"); shift 2 ;;
          --node)
            [[ $# -ge 2 ]] || die "cf dns plan: --node needs a value"
            args+=("$1" "$2"); shift 2 ;;
          --ipv4)
            [[ $# -ge 2 ]] || die "cf dns plan: --ipv4 needs a value"
            args+=("$1" "$2"); shift 2 ;;
          --ipv6)
            [[ $# -ge 2 ]] || die "cf dns plan: --ipv6 needs a value"
            args+=("$1" "$2"); shift 2 ;;
          --json)
            args+=("--json"); shift ;;
          --dry-run)
            # cf dns plan is already dry-run only (no mutation).
            # Ignore global --dry-run so validation still runs.
            shift ;;
          *)
            die "cf dns plan: unknown option: $1"
            ;;
        esac
      done

      "${args[@]}"
      ;;

    validate-profile)
      local args=(python3 "$dns_script" validate-profile)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --profile)
            [[ $# -ge 2 ]] || die "cf dns validate-profile: --profile needs a path argument"
            args+=("$1" "$2"); shift 2 ;;
          --dry-run)
            # cf dns validate-profile is already dry-run only (no mutation).
            # Ignore global --dry-run so validation still runs.
            shift ;;
          *)
            die "cf dns validate-profile: unknown option: $1"
            ;;
        esac
      done

      "${args[@]}"
      ;;

    apply)
      local apply_script="${REPO_DIR}/lib/nanobk_cf_dns_apply.py"
      [[ -f "$apply_script" ]] || die "DNS apply script not found: ${apply_script}"
      local args=(python3 "$apply_script")
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --help|-h)
            args+=("--help"); shift ;;
          --profile)
            [[ $# -ge 2 ]] || die "cf dns apply: --profile needs a path argument"
            args+=("$1" "$2"); shift 2 ;;
          --api-env)
            [[ $# -ge 2 ]] || die "cf dns apply: --api-env needs a path argument"
            args+=("$1" "$2"); shift 2 ;;
          --dry-run)
            args+=("--dry-run"); shift ;;
          --check)
            args+=("--check"); shift ;;
          --yes)
            args+=("--yes"); shift ;;
          --json)
            args+=("--json"); shift ;;
          --force)
            args+=("--force"); shift ;;
          *)
            die "cf dns apply: unknown option: $1"
            ;;
        esac
      done

      "${args[@]}"
      ;;

    readiness)
      local args=(python3 "$REPO_DIR/lib/nanobk_cf_dns_readiness.py")
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --api-env)
            [[ $# -ge 2 ]] || die "cf dns readiness: --api-env needs a path argument"
            args+=("$1" "$2"); shift 2 ;;
          --profile)
            [[ $# -ge 2 ]] || die "cf dns readiness: --profile needs a path argument"
            args+=("$1" "$2"); shift 2 ;;
          --json)
            args+=("--json"); shift ;;
          --help|-h)
            args+=("--help"); shift ;;
          --dry-run)
            print_cmd "${args[@]}"
            echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
            return 0 ;;
          *)
            die "cf dns readiness: unknown option: $1"
            ;;
        esac
      done

      # Respect global --dry-run
      if [[ "$DRY_RUN" == "1" ]]; then
        print_cmd "${args[@]}"
        echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
        return 0
      fi

      "${args[@]}"
      ;;

    target)
      local target_sub="${1:-}"
      shift 2>/dev/null || true
      case "$target_sub" in
        preview)
          local args=(python3 "$REPO_DIR/lib/nanobk_cf_dns_targets.py")
          while [[ $# -gt 0 ]]; do
            case "$1" in
              --zone)
                [[ $# -ge 2 ]] || die "cf dns target preview: --zone needs a value"
                args+=("$1" "$2"); shift 2 ;;
              --node)
                [[ $# -ge 2 ]] || die "cf dns target preview: --node needs a value"
                args+=("$1" "$2"); shift 2 ;;
              --ip-fixture)
                [[ $# -ge 2 ]] || die "cf dns target preview: --ip-fixture needs a path"
                args+=("$1" "$2"); shift 2 ;;
              --json)
                args+=("--json"); shift ;;
              --help|-h)
                args+=("--help"); shift ;;
              --dry-run)
                print_cmd "${args[@]}"
                echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
                return 0 ;;
              *)
                die "cf dns target preview: unknown option: $1"
                ;;
            esac
          done
          # Respect global --dry-run
          if [[ "$DRY_RUN" == "1" ]]; then
            print_cmd "${args[@]}"
            echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
            return 0
          fi
          "${args[@]}"
          ;;
        "")
          die "Usage: nanobk cf dns target <preview> [options...]"
          ;;
        *)
          die "Unknown cf dns target subcommand: ${target_sub}. Use: nanobk cf dns target preview"
          ;;
      esac
      ;;

    availability)
      local avail_sub="${1:-}"
      shift 2>/dev/null || true
      case "$avail_sub" in
        check)
          local args=(python3 "$REPO_DIR/lib/nanobk_cf_dns_availability.py" check)
          while [[ $# -gt 0 ]]; do
            case "$1" in
              --zone)
                [[ $# -ge 2 ]] || die "cf dns availability check: --zone needs a value"
                args+=("$1" "$2"); shift 2 ;;
              --node)
                [[ $# -ge 2 ]] || die "cf dns availability check: --node needs a value"
                args+=("$1" "$2"); shift 2 ;;
              --api-env)
                [[ $# -ge 2 ]] || die "cf dns availability check: --api-env needs a path"
                args+=("$1" "$2"); shift 2 ;;
              --json)
                args+=("--json"); shift ;;
              --help|-h)
                args+=("--help"); shift ;;
              --dry-run)
                print_cmd "${args[@]}"
                echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
                return 0 ;;
              *)
                die "cf dns availability check: unknown option: $1"
                ;;
            esac
          done
          # Respect global --dry-run
          if [[ "$DRY_RUN" == "1" ]]; then
            print_cmd "${args[@]}"
            echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
            return 0
          fi
          "${args[@]}"
          ;;
        summary)
          local args=(python3 "$REPO_DIR/lib/nanobk_cf_dns_availability.py" summary)
          while [[ $# -gt 0 ]]; do
            case "$1" in
              --zone)
                [[ $# -ge 2 ]] || die "cf dns availability summary: --zone needs a value"
                args+=("$1" "$2"); shift 2 ;;
              --api-env)
                [[ $# -ge 2 ]] || die "cf dns availability summary: --api-env needs a path"
                args+=("$1" "$2"); shift 2 ;;
              --nodes)
                [[ $# -ge 2 ]] || die "cf dns availability summary: --nodes needs a value"
                args+=("$1" "$2"); shift 2 ;;
              --json)
                args+=("--json"); shift ;;
              --help|-h)
                args+=("--help"); shift ;;
              --dry-run)
                print_cmd "${args[@]}"
                echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
                return 0 ;;
              *)
                die "cf dns availability summary: unknown option: $1"
                ;;
            esac
          done
          # Respect global --dry-run
          if [[ "$DRY_RUN" == "1" ]]; then
            print_cmd "${args[@]}"
            echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
            return 0
          fi
          "${args[@]}"
          ;;
        "")
          die "Usage: nanobk cf dns availability <check|summary> [options...]"
          ;;
        *)
          die "Unknown cf dns availability subcommand: ${avail_sub}. Use: nanobk cf dns availability <check|summary>"
          ;;
      esac
      ;;

    report)
      local args=(python3 "$REPO_DIR/lib/nanobk_cf_dns_report.py")
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --zone)
            [[ $# -ge 2 ]] || die "cf dns report: --zone needs a value"
            args+=("$1" "$2"); shift 2 ;;
          --api-env)
            [[ $# -ge 2 ]] || die "cf dns report: --api-env needs a path"
            args+=("$1" "$2"); shift 2 ;;
          --ip-fixture)
            [[ $# -ge 2 ]] || die "cf dns report: --ip-fixture needs a path"
            args+=("$1" "$2"); shift 2 ;;
          --nodes)
            [[ $# -ge 2 ]] || die "cf dns report: --nodes needs a value"
            args+=("$1" "$2"); shift 2 ;;
          --json)
            args+=("--json"); shift ;;
          --help|-h)
            args+=("--help"); shift ;;
          --dry-run)
            print_cmd "${args[@]}"
            echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
            return 0 ;;
          *)
            die "cf dns report: unknown option: $1"
            ;;
        esac
      done
      # Respect global --dry-run
      if [[ "$DRY_RUN" == "1" ]]; then
        print_cmd "${args[@]}"
        echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
        return 0
      fi
      "${args[@]}"
      ;;

    profile)
      local profile_sub="${1:-}"
      shift 2>/dev/null || true
      case "$profile_sub" in
        preview)
          local args=(python3 "$REPO_DIR/lib/nanobk_cf_dns_profile.py" preview)
          while [[ $# -gt 0 ]]; do
            case "$1" in
              --zone)
                [[ $# -ge 2 ]] || die "cf dns profile preview: --zone needs a value"
                args+=("$1" "$2"); shift 2 ;;
              --node)
                [[ $# -ge 2 ]] || die "cf dns profile preview: --node needs a value"
                args+=("$1" "$2"); shift 2 ;;
              --ipv4)
                [[ $# -ge 2 ]] || die "cf dns profile preview: --ipv4 needs a value"
                args+=("$1" "$2"); shift 2 ;;
              --ipv6)
                [[ $# -ge 2 ]] || die "cf dns profile preview: --ipv6 needs a value"
                args+=("$1" "$2"); shift 2 ;;
              --allow-documentation-ips)
                args+=("--allow-documentation-ips"); shift ;;
              --json)
                args+=("--json"); shift ;;
              --help|-h)
                args+=("--help"); shift ;;
              --dry-run)
                # Sanitized dry-run: do not echo raw zone/IP args
                echo -e "  ${CYAN}[DRY-RUN]${NC} nanobk cf dns profile preview would run; raw zone and IP arguments are hidden"
                return 0 ;;
              *)
                die "cf dns profile preview: unknown option: $1"
                ;;
            esac
          done
          # Respect global --dry-run (sanitized)
          if [[ "$DRY_RUN" == "1" ]]; then
            echo -e "  ${CYAN}[DRY-RUN]${NC} nanobk cf dns profile preview would run; raw zone and IP arguments are hidden"
            return 0
          fi
          "${args[@]}"
          ;;
        generate)
          local args=(python3 "$REPO_DIR/lib/nanobk_cf_dns_profile.py" generate)
          while [[ $# -gt 0 ]]; do
            case "$1" in
              --zone)
                [[ $# -ge 2 ]] || die "cf dns profile generate: --zone needs a value"
                args+=("$1" "$2"); shift 2 ;;
              --node)
                [[ $# -ge 2 ]] || die "cf dns profile generate: --node needs a value"
                args+=("$1" "$2"); shift 2 ;;
              --ipv4)
                [[ $# -ge 2 ]] || die "cf dns profile generate: --ipv4 needs a value"
                args+=("$1" "$2"); shift 2 ;;
              --ipv6)
                [[ $# -ge 2 ]] || die "cf dns profile generate: --ipv6 needs a value"
                args+=("$1" "$2"); shift 2 ;;
              --output)
                [[ $# -ge 2 ]] || die "cf dns profile generate: --output needs a path"
                args+=("$1" "$2"); shift 2 ;;
              --yes)
                args+=("--yes"); shift ;;
              --allow-production-output)
                args+=("--allow-production-output"); shift ;;
              --confirm-hostname)
                [[ $# -ge 2 ]] || die "cf dns profile generate: --confirm-hostname needs a value"
                args+=("$1" "$2"); shift 2 ;;
              --allow-documentation-ips)
                args+=("--allow-documentation-ips"); shift ;;
              --json)
                args+=("--json"); shift ;;
              --help|-h)
                args+=("--help"); shift ;;
              --dry-run)
                # Sanitized dry-run: do not echo raw args
                echo -e "  ${CYAN}[DRY-RUN]${NC} nanobk cf dns profile generate would run; raw zone, IP, confirmation, and output path arguments are hidden; no filesystem checks performed"
                return 0 ;;
              *)
                die "cf dns profile generate: unknown option: $1"
                ;;
            esac
          done
          # Respect global --dry-run (sanitized)
          if [[ "$DRY_RUN" == "1" ]]; then
            echo -e "  ${CYAN}[DRY-RUN]${NC} nanobk cf dns profile generate would run; raw zone, IP, confirmation, and output path arguments are hidden; no filesystem checks performed"
            return 0
          fi
          "${args[@]}"
          ;;
        replace)
          local replace_sub="${1:-}"
          shift 2>/dev/null || true
          case "$replace_sub" in
            preview)
              local args=(python3 "$REPO_DIR/lib/nanobk_cf_dns_profile.py" replace preview)
              while [[ $# -gt 0 ]]; do
                case "$1" in
                  --zone)
                    [[ $# -ge 2 ]] || die "cf dns profile replace preview: --zone needs a value"
                    args+=("$1" "$2"); shift 2 ;;
                  --node)
                    [[ $# -ge 2 ]] || die "cf dns profile replace preview: --node needs a value"
                    args+=("$1" "$2"); shift 2 ;;
                  --ipv4)
                    [[ $# -ge 2 ]] || die "cf dns profile replace preview: --ipv4 needs a value"
                    args+=("$1" "$2"); shift 2 ;;
                  --ipv6)
                    [[ $# -ge 2 ]] || die "cf dns profile replace preview: --ipv6 needs a value"
                    args+=("$1" "$2"); shift 2 ;;
                  --output)
                    [[ $# -ge 2 ]] || die "cf dns profile replace preview: --output needs a path"
                    args+=("$1" "$2"); shift 2 ;;
                  --allow-production-output)
                    args+=("--allow-production-output"); shift ;;
                  --confirm-hostname)
                    [[ $# -ge 2 ]] || die "cf dns profile replace preview: --confirm-hostname needs a value"
                    args+=("$1" "$2"); shift 2 ;;
                  --allow-documentation-ips)
                    args+=("--allow-documentation-ips"); shift ;;
                  --json)
                    args+=("--json"); shift ;;
                  --help|-h)
                    args+=("--help"); shift ;;
                  --dry-run)
                    echo -e "  ${CYAN}[DRY-RUN]${NC} nanobk cf dns profile replace preview would run; raw zone, IP, confirmation, and output path arguments are hidden; no filesystem checks performed"
                    return 0 ;;
                  *)
                    die "cf dns profile replace preview: unknown option: $1"
                    ;;
                esac
              done
              # Respect global --dry-run (sanitized)
              if [[ "$DRY_RUN" == "1" ]]; then
                echo -e "  ${CYAN}[DRY-RUN]${NC} nanobk cf dns profile replace preview would run; raw zone, IP, confirmation, and output path arguments are hidden; no filesystem checks performed"
                return 0
              fi
              "${args[@]}"
              ;;
            "")
              die "Usage: nanobk cf dns profile replace <preview> [options...]"
              ;;
            *)
              die "Unknown cf dns profile replace subcommand: ${replace_sub}. Use: nanobk cf dns profile replace preview"
              ;;
          esac
          ;;
        backup)
          local args=(python3 "$REPO_DIR/lib/nanobk_cf_dns_profile.py" backup)
          while [[ $# -gt 0 ]]; do
            case "$1" in
              --profile)
                [[ $# -ge 2 ]] || die "cf dns profile backup: --profile needs a path"
                args+=("$1" "$2"); shift 2 ;;
              --allow-production-output)
                args+=("--allow-production-output"); shift ;;
              --confirm-hostname)
                [[ $# -ge 2 ]] || die "cf dns profile backup: --confirm-hostname needs a value"
                args+=("$1" "$2"); shift 2 ;;
              --yes)
                args+=("--yes"); shift ;;
              --json)
                args+=("--json"); shift ;;
              --help|-h)
                args+=("--help"); shift ;;
              --dry-run)
                echo -e "  ${CYAN}[DRY-RUN]${NC} nanobk cf dns profile backup would run; raw confirmation and profile path arguments are hidden; no filesystem checks performed"
                return 0 ;;
              *)
                die "cf dns profile backup: unknown option: $1"
                ;;
            esac
          done
          # Respect global --dry-run (sanitized)
          if [[ "$DRY_RUN" == "1" ]]; then
            echo -e "  ${CYAN}[DRY-RUN]${NC} nanobk cf dns profile backup would run; raw confirmation and profile path arguments are hidden; no filesystem checks performed"
            return 0
          fi
          "${args[@]}"
          ;;
        "")
          die "Usage: nanobk cf dns profile <preview|generate|replace|backup> [options...]"
          ;;
        *)
          die "Unknown cf dns profile subcommand: ${profile_sub}. Use: nanobk cf dns profile <preview|generate|replace|backup>"
          ;;
      esac
      ;;

    "")
      die "Usage: nanobk cf dns <plan|validate-profile|apply|readiness|target|availability|report|profile> [options...]"
      ;;

    *)
      die "Unknown cf dns subcommand: ${dns_sub}. Use: nanobk cf dns <plan|validate-profile|apply|readiness|target|availability|report|profile>"
      ;;
  esac
}

# ── cf zones ──────────────────────────────────────────────────────────────

cmd_cf_zones() {
  local zones_sub="${1:-}"
  shift 2>/dev/null || true

  case "$zones_sub" in
    list)
      local args=(python3 "$REPO_DIR/lib/nanobk_cf_zones.py" list)
      local json_mode=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --api-env)
            [[ $# -ge 2 ]] || die "cf zones list: --api-env needs a path argument"
            args+=("$1" "$2"); shift 2 ;;
          --json)
            json_mode=1; args+=("--json"); shift ;;
          --help|-h)
            args+=("--help"); shift ;;
          --dry-run)
            print_cmd "${args[@]}"
            echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
            return 0 ;;
          *)
            die "cf zones list: unknown option: $1"
            ;;
        esac
      done

      if [[ "$DRY_RUN" == "1" ]]; then
        print_cmd "${args[@]}"
        echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
        return 0
      fi

      "${args[@]}"
      ;;

    "")
      die "Usage: nanobk cf zones list --api-env PATH [--json]"
      ;;

    *)
      die "Unknown cf zones subcommand: ${zones_sub}. Use: nanobk cf zones list"
      ;;
  esac
}

# ── vps ip detect ────────────────────────────────────────────────────────

cmd_vps_ip_detect() {
  local args=(python3 "$REPO_DIR/lib/nanobk_ip_detect.py" detect)
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)
        args+=("--json"); shift ;;
      --help|-h)
        echo "Usage: nanobk vps ip detect [--json]"
        echo ""
        echo "  Read-only VPS IP candidate detection and classification."
        echo "  Uses test fixtures only (NANOBK_IP_DETECT_FIXTURE)."
        echo "  Output is masked/redacted by default."
        echo "  No DNS mutation. No Cloudflare calls."
        return 0 ;;
      --dry-run)
        print_cmd "${args[@]}"
        echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
        return 0 ;;
      *)
        die "vps ip detect: unknown option: $1"
        ;;
    esac
  done

  # Respect global --dry-run
  if [[ "$DRY_RUN" == "1" ]]; then
    print_cmd "${args[@]}"
    echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
    return 0
  fi

  "${args[@]}"
}

# ── rotate ──────────────────────────────────────────────────────────────────

cmd_rotate() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    all|hy2|tuic|reality|trojan)
      local cmd=(bash "$REPO_DIR/vps/scripts/rotate-keys.sh" --protocol "$subcmd")
      local has_dry_run=0
      for arg in "$@"; do
        [[ "$arg" == "--dry-run" ]] && has_dry_run=1
      done
      [[ "$DRY_RUN" == "1" && "$has_dry_run" == "0" ]] && cmd+=(--dry-run)
      cmd+=("$@")
      run_script "换密钥 (${subcmd})" "${cmd[@]}"
      ;;
    "")
      die "Usage: nanobk rotate <all|hy2|tuic|reality|trojan> [args...]"
      ;;
    *)
      die "Unknown rotate subcommand: ${subcmd}. Use: nanobk rotate <all|hy2|tuic|reality|trojan>"
      ;;
  esac
}

# ── export ─────────────────────────────────────────────────────────────────

cmd_export() {
  local subcmd="${1:-}"
  shift || true

  case "$subcmd" in
    link)
      local protocol="${1:-}"
      shift || true
      if [[ -z "$protocol" ]]; then
        die "用法: nanobk export link <hy2|tuic|reality|trojan> [--profile PATH] [--json]"
      fi

      local profile_path="${CONFIG_DIR}/profile.current.json"
      local json_mode="$JSON_OUT"

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --profile)
            [[ $# -ge 2 ]] || die "export link: --profile 需要路径参数"
            profile_path="$2"; shift 2 ;;
          --json)     json_mode=1; shift ;;
          --dry-run)  DRY_RUN=1; shift ;;
          *)          die "export link: 未知选项: $1" ;;
        esac
      done

      [[ -f "$profile_path" ]] || die "配置文件不存在: ${profile_path}"

      local export_script="${REPO_DIR}/lib/nanobk_export_links.py"
      [[ -f "$export_script" ]] || die "导出脚本不存在: ${export_script}"

      local args=(
        python3 "$export_script"
        --profile "$profile_path"
        --protocol "$protocol"
      )
      if [[ "$json_mode" == "1" ]]; then
        args+=(--json)
      fi

      if [[ "$DRY_RUN" == "1" ]]; then
        print_cmd "${args[@]}"
        echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
        return 0
      fi

      "${args[@]}"
      ;;

    links)
      local profile_path="${CONFIG_DIR}/profile.current.json"
      local json_mode="$JSON_OUT"

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --profile)
            [[ $# -ge 2 ]] || die "export links: --profile 需要路径参数"
            profile_path="$2"; shift 2 ;;
          --json)     json_mode=1; shift ;;
          --dry-run)  DRY_RUN=1; shift ;;
          *)          die "export links: 未知选项: $1" ;;
        esac
      done

      [[ -f "$profile_path" ]] || die "配置文件不存在: ${profile_path}"

      local export_script="${REPO_DIR}/lib/nanobk_export_links.py"
      [[ -f "$export_script" ]] || die "导出脚本不存在: ${export_script}"

      local args=(
        python3 "$export_script"
        --profile "$profile_path"
        --protocol all
      )
      if [[ "$json_mode" == "1" ]]; then
        args+=(--json)
      fi

      if [[ "$DRY_RUN" == "1" ]]; then
        print_cmd "${args[@]}"
        echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
        return 0
      fi

      "${args[@]}"
      ;;

    *)
      die "用法: nanobk export <link|links> [选项...]"
      ;;
  esac
}

# ── test ────────────────────────────────────────────────────────────────────

cmd_test() {
  local run_all=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --all) run_all=1 ;;
      --dry-run) DRY_RUN=1 ;;
      *) die "Unknown test option: $1" ;;
    esac
    shift
  done

  local scripts=(
    "$REPO_DIR/tests/bootstrap-dry-run.sh"
    "$REPO_DIR/tests/render-install-vps.sh"
    "$REPO_DIR/tests/rotate-render-only.sh"
    "$REPO_DIR/tests/export-links.sh"
  )

  if [[ "$run_all" == "1" ]]; then
    scripts+=(
      "$REPO_DIR/tests/wrangler-nanok-dry-run.sh"
      "$REPO_DIR/tests/wrangler-nanob-dry-run.sh"
      "$REPO_DIR/tests/cf-dns-plan.sh"
      "$REPO_DIR/tests/cf-dns-apply.sh"
    )
  fi

  local failed=0
  for script in "${scripts[@]}"; do
    local label
    label="$(basename "$script" .sh)"

    if [[ "$DRY_RUN" == "1" ]]; then
      echo -e "  ${CYAN}[DRY-RUN]${NC} bash ${script}"
      continue
    fi

    log "运行: ${label}"
    if bash "$script"; then
      ok "${label}: passed"
    else
      warn "${label}: failed"
      failed=$((failed + 1))
    fi
    echo ""
  done

  if [[ "$DRY_RUN" == "1" ]]; then
    return 0
  fi

  if [[ $failed -gt 0 ]]; then
    die "${failed} test(s) failed"
  fi
  ok "All tests passed"
}

# ── Argument parsing ────────────────────────────────────────────────────────

parse_global_args() {
  CMD_ARGS=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo-dir)   REPO_DIR="$2"; shift 2 ;;
      --dry-run)    DRY_RUN=1; shift ;;
      --json)       JSON_OUT=1; shift ;;
      --help|-h)    cmd_help; exit 0 ;;
      --version|-v) cmd_version; exit 0 ;;
      -*)           die "Unknown global option: $1. Use --help for usage." ;;
      *)            CMD_ARGS=("$@"); return ;;
    esac
  done
}

# ── Main ────────────────────────────────────────────────────────────────────

main() {
  parse_global_args "$@"

  local command="${CMD_ARGS[0]:-}"
  local cmd_rest=()
  if [[ ${#CMD_ARGS[@]} -gt 1 ]]; then
    cmd_rest=("${CMD_ARGS[@]:1}")
  fi

  resolve_repo_dir

  case "$command" in
    status)       cmd_status ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    doctor)       cmd_doctor ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    install)      cmd_install ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    install-cli)  cmd_install_cli ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    cf)
      local cf_sub="${cmd_rest[0]:-}"
      local cf_rest=()
      if [[ ${#cmd_rest[@]} -gt 1 ]]; then
        cf_rest=("${cmd_rest[@]:1}")
      fi
      case "$cf_sub" in
        deploy)  cmd_cf_deploy ${cf_rest[@]+"${cf_rest[@]}"} ;;
        verify)  cmd_cf_verify ${cf_rest[@]+"${cf_rest[@]}"} ;;
        install-admin-env) cmd_cf_install_admin_env ;;
        dns)     cmd_cf_dns ${cf_rest[@]+"${cf_rest[@]}"} ;;
        zones)   cmd_cf_zones ${cf_rest[@]+"${cf_rest[@]}"} ;;
        *)       die "Usage: nanobk cf <deploy|verify|install-admin-env|dns|zones> [args...]" ;;
      esac
      ;;
    vps)
      local vps_sub="${cmd_rest[0]:-}"
      local vps_rest=()
      if [[ ${#cmd_rest[@]} -gt 1 ]]; then
        vps_rest=("${cmd_rest[@]:1}")
      fi
      case "$vps_sub" in
        ip)
          local ip_sub="${vps_rest[0]:-}"
          local ip_rest=()
          if [[ ${#vps_rest[@]} -gt 1 ]]; then
            ip_rest=("${vps_rest[@]:1}")
          fi
          case "$ip_sub" in
            detect)  cmd_vps_ip_detect ${ip_rest[@]+"${ip_rest[@]}"} ;;
            *)       die "Usage: nanobk vps ip <detect> [args...]" ;;
          esac
          ;;
        *)       die "Usage: nanobk vps <ip> [args...]" ;;
      esac
      ;;
    rotate)   cmd_rotate ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    export)   cmd_export ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    test)     cmd_test ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    version)  cmd_version ;;
    console)  cmd_console ;;
    "")       cmd_entry ;;
    *)        die "Unknown command: ${command}. Use --help for usage." ;;
  esac
}

main "$@"
