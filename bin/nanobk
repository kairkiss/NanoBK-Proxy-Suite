# ── setup dns apply ─────────────────────────────────────────────────────

cmd_setup_dns_apply() {
  local zone="" api_env="" apply_mode=0 confirm=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --zone)
        [[ $# -ge 2 ]] || die "setup dns apply: --zone needs a value"
        zone="$2"; shift 2 ;;
      --api-env)
        [[ $# -ge 2 ]] || die "setup dns apply: --api-env needs a path"
        api_env="$2"; shift 2 ;;
      --apply)
        apply_mode=1; shift ;;
      --confirm)
        [[ $# -ge 2 ]] || die "setup dns apply: --confirm needs a value"
        confirm="$2"; shift 2 ;;
      --json)
        JSON_OUT=1; shift ;;
      --dry-run)
        echo -e "  ${CYAN}[DRY-RUN]${NC} setup dns apply command prepared"
        echo "  No DNS mutation will be performed."
        return 0 ;;
      --help|-h)
        echo "Usage: nanobk setup dns apply [--zone DOMAIN] [--api-env PATH] [--apply] [--confirm PHRASE] [--json]"
        echo ""
        echo "  DNS 创建引擎（默认只显示预案）。"
        echo "  带 --apply + --confirm 才会真正创建 DNS。"
        return 0 ;;
      *)
        die "setup dns apply: unknown option: $1"
        ;;
    esac
  done

  if [[ "$DRY_RUN" == "1" ]]; then
    echo -e "  ${CYAN}[DRY-RUN]${NC} setup dns apply command prepared"
    echo "  No DNS mutation will be performed."
    return 0
  fi

  local args=(python3 "$REPO_DIR/lib/nanobk_dns_apply_engine.py")
  [[ -n "$zone" ]] && args+=(--zone "$zone")
  [[ -n "$api_env" ]] && args+=(--api-env "$api_env")
  [[ "$apply_mode" == "1" ]] && args+=(--apply)
  [[ -n "$confirm" ]] && args+=(--confirm "$confirm")
  [[ "$JSON_OUT" == "1" ]] && args+=(--json)

  "${args[@]}"
}

