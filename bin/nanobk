      ;;

    create-preflight)
      local args=(python3 "$REPO_DIR/lib/nanobk_cf_dns_create_preflight.py" preflight)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --zone)
            [[ $# -ge 2 ]] || die "cf dns create-preflight: --zone needs a value"
