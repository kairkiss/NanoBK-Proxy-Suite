                args+=("--help"); shift ;;
              --dry-run)
                print_cmd "${args[@]}"
                echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
                return 0 ;;
              *)
                die "cf dns availability summary: unknown option: $1"
                ;;
            esac
          done
          # Respect global --dry-run
          if [[ "$DRY_RUN" == "1" ]]; then
            print_cmd "${args[@]}"
            echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
            return 0
          fi
          "${args[@]}"
          ;;
        "")
          die "Usage: nanobk cf dns availability <check|summary> [options...]"
          ;;
        *)
          die "Unknown cf dns availability subcommand: ${avail_sub}. Use: nanobk cf dns availability <check|summary>"
          ;;
      esac
      ;;

    plan-generator)
      local args=(python3 "$REPO_DIR/lib/nanobk_cf_dns_plan_generator.py" generate)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --zone)
            [[ $# -ge 2 ]] || die "cf dns plan-generator: --zone needs a value"
