# ── setup production ─────────────────────────────────────────────────────

cmd_setup_production() {
  local subcommand=""
  local use_json=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)
        use_json=1; shift ;;
      status)
        subcommand="status"; shift ;;
      plan)
        subcommand="plan"; shift ;;
      --help|-h)
        echo "Usage: nanobk setup production [--json]"
        echo "       nanobk setup production status [--json]"
        echo "       nanobk setup production plan [--json]"
        echo ""
        echo "  生产设置主线（只读，不会执行部署）。"
        echo "  显示完整的生产部署路线图和旧能力入口映射。"
        echo "  Read-only. No DNS mutation. No Cloudflare mutation."
        return 0 ;;
      --dry-run)
        echo -e "  ${CYAN}[DRY-RUN]${NC} setup production command prepared"
        echo "  No mutations will be performed."
        return 0 ;;
      *)
        die "setup production: unknown option: $1"
        ;;
    esac
  done
  if [[ "$DRY_RUN" == "1" ]]; then
    echo -e "  ${CYAN}[DRY-RUN]${NC} setup production command prepared"
    echo "  No mutations will be performed."
    return 0
  fi
  local args=(python3 "$REPO_DIR/lib/nanobk_production_setup_spine.py")
  [[ -n "$subcommand" ]] && args+=("$subcommand")
  [[ "$use_json" == "1" ]] && args+=("--json")
  "${args[@]}"
}

# ── vps ip detect ────────────────────────────────────────────────────────

cmd_vps_ip_detect() {
  local args=(python3 "$REPO_DIR/lib/nanobk_ip_detect.py" detect)
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)
        args+=("--json"); shift ;;
      --help|-h)
        echo "Usage: nanobk vps ip detect [--json]"
        echo ""
        echo "  Detects public IPv4/IPv6 using safe read-only checks."
        echo "  Supports test fixtures via NANOBK_IP_DETECT_FIXTURE."
        echo "  No DNS mutation. No Cloudflare calls. No system changes."
        return 0 ;;
      --dry-run)
        print_cmd "${args[@]}"
        echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
        return 0 ;;
      *)
        die "vps ip detect: unknown option: $1"
        ;;
    esac
  done

  # Respect global --dry-run
  if [[ "$DRY_RUN" == "1" ]]; then
    print_cmd "${args[@]}"
    echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
    return 0
  fi

  "${args[@]}"
}

# ── rotate ──────────────────────────────────────────────────────────────────

cmd_rotate() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    all|hy2|tuic|reality|trojan)
      local cmd=(bash "$REPO_DIR/vps/scripts/rotate-keys.sh" --protocol "$subcmd")
      local has_dry_run=0
      for arg in "$@"; do
        [[ "$arg" == "--dry-run" ]] && has_dry_run=1
      done
      [[ "$DRY_RUN" == "1" && "$has_dry_run" == "0" ]] && cmd+=(--dry-run)
      cmd+=("$@")
      run_script "换密钥 (${subcmd})" "${cmd[@]}"
      ;;
    "")
      die "Usage: nanobk rotate <all|hy2|tuic|reality|trojan> [args...]"
      ;;
    *)
      die "Unknown rotate subcommand: ${subcmd}. Use: nanobk rotate <all|hy2|tuic|reality|trojan>"
      ;;
  esac
}

# ── export ─────────────────────────────────────────────────────────────────

cmd_export() {
  local subcmd="${1:-}"
  shift || true

  case "$subcmd" in
    link)
      local protocol="${1:-}"
      shift || true
      if [[ -z "$protocol" ]]; then
        die "用法: nanobk export link <hy2|tuic|reality|trojan> [--profile PATH] [--json]"
      fi

      local profile_path="${CONFIG_DIR}/profile.current.json"
      local json_mode="$JSON_OUT"

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --profile)
            [[ $# -ge 2 ]] || die "export link: --profile 需要路径参数"
            profile_path="$2"; shift 2 ;;
          --json)     json_mode=1; shift ;;
          --dry-run)  DRY_RUN=1; shift ;;
          *)          die "export link: 未知选项: $1" ;;
        esac
      done

      [[ -f "$profile_path" ]] || die "配置文件不存在: ${profile_path}"

      local export_script="${REPO_DIR}/lib/nanobk_export_links.py"
      [[ -f "$export_script" ]] || die "导出脚本不存在: ${export_script}"

      local args=(
        python3 "$export_script"
        --profile "$profile_path"
        --protocol "$protocol"
      )
      if [[ "$json_mode" == "1" ]]; then
        args+=(--json)
      fi

      if [[ "$DRY_RUN" == "1" ]]; then
        print_cmd "${args[@]}"
        echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
        return 0
      fi

      "${args[@]}"
      ;;

    links)
      local profile_path="${CONFIG_DIR}/profile.current.json"
      local json_mode="$JSON_OUT"

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --profile)
            [[ $# -ge 2 ]] || die "export links: --profile 需要路径参数"
            profile_path="$2"; shift 2 ;;
          --json)     json_mode=1; shift ;;
          --dry-run)  DRY_RUN=1; shift ;;
          *)          die "export links: 未知选项: $1" ;;
        esac
      done

      [[ -f "$profile_path" ]] || die "配置文件不存在: ${profile_path}"

      local export_script="${REPO_DIR}/lib/nanobk_export_links.py"
      [[ -f "$export_script" ]] || die "导出脚本不存在: ${export_script}"

      local args=(
        python3 "$export_script"
        --profile "$profile_path"
        --protocol all
      )
      if [[ "$json_mode" == "1" ]]; then
        args+=(--json)
      fi

      if [[ "$DRY_RUN" == "1" ]]; then
        print_cmd "${args[@]}"
        echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
        return 0
      fi

      "${args[@]}"
      ;;

    *)
      die "用法: nanobk export <link|links> [选项...]"
      ;;
  esac
}

# ── test ────────────────────────────────────────────────────────────────────

cmd_test() {
  local run_all=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --all) run_all=1 ;;
      --dry-run) DRY_RUN=1 ;;
      *) die "Unknown test option: $1" ;;
    esac
    shift
  done

  local scripts=(
    "$REPO_DIR/tests/bootstrap-dry-run.sh"
    "$REPO_DIR/tests/render-install-vps.sh"
    "$REPO_DIR/tests/rotate-render-only.sh"
    "$REPO_DIR/tests/export-links.sh"
  )

  if [[ "$run_all" == "1" ]]; then
    scripts+=(
      "$REPO_DIR/tests/wrangler-nanok-dry-run.sh"
      "$REPO_DIR/tests/wrangler-nanob-dry-run.sh"
      "$REPO_DIR/tests/cf-dns-plan.sh"
      "$REPO_DIR/tests/cf-dns-apply.sh"
      "$REPO_DIR/tests/cf-dns-profile-preview.sh"
      "$REPO_DIR/tests/cf-dns-profile-generate.sh"
      "$REPO_DIR/tests/cf-dns-profile-production.sh"
      "$REPO_DIR/tests/cf-dns-profile-backup.sh"
      "$REPO_DIR/tests/cf-dns-profile-replace-preview.sh"
      "$REPO_DIR/tests/cf-dns-profile-rollback-preview.sh"
      "$REPO_DIR/tests/cf-dns-profile-rollback-execute.sh"
    )
  fi

  local failed=0
  for script in "${scripts[@]}"; do
    local label
    label="$(basename "$script" .sh)"

    if [[ "$DRY_RUN" == "1" ]]; then
      echo -e "  ${CYAN}[DRY-RUN]${NC} bash ${script}"
      continue
    fi

    log "运行: ${label}"
    if bash "$script"; then
      ok "${label}: passed"
    else
      warn "${label}: failed"
      failed=$((failed + 1))
    fi
    echo ""
  done

  if [[ "$DRY_RUN" == "1" ]]; then
    return 0
  fi

  if [[ $failed -gt 0 ]]; then
    die "${failed} test(s) failed"
  fi
  ok "All tests passed"
}

# ── Argument parsing ────────────────────────────────────────────────────────

parse_global_args() {
  CMD_ARGS=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo-dir)   REPO_DIR="$2"; shift 2 ;;
      --dry-run)    DRY_RUN=1; shift ;;
      --json)       JSON_OUT=1; shift ;;
      --help|-h)    cmd_help; exit 0 ;;
      --version|-v) cmd_version; exit 0 ;;
      -*)           die "Unknown global option: $1. Use --help for usage." ;;
      *)            CMD_ARGS=("$@"); return ;;
    esac
  done
}

# ── Main ────────────────────────────────────────────────────────────────────

main() {
  parse_global_args "$@"

  local command="${CMD_ARGS[0]:-}"
  local cmd_rest=()
  if [[ ${#CMD_ARGS[@]} -gt 1 ]]; then
    cmd_rest=("${CMD_ARGS[@]:1}")
  fi

  resolve_repo_dir

  case "$command" in
    home)         cmd_home ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    beginner)     cmd_beginner ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    status)       cmd_status ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    doctor)       cmd_doctor ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    install)      cmd_install ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    install-cli)  cmd_install_cli ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    cf)
      local cf_sub="${cmd_rest[0]:-}"
      local cf_rest=()
      if [[ ${#cmd_rest[@]} -gt 1 ]]; then
        cf_rest=("${cmd_rest[@]:1}")
      fi
      case "$cf_sub" in
        connect) cmd_cf_connect ${cf_rest[@]+"${cf_rest[@]}"} ;;
        deploy)  cmd_cf_deploy ${cf_rest[@]+"${cf_rest[@]}"} ;;
        verify)  cmd_cf_verify ${cf_rest[@]+"${cf_rest[@]}"} ;;
        install-admin-env) cmd_cf_install_admin_env ;;
        dns)     cmd_cf_dns ${cf_rest[@]+"${cf_rest[@]}"} ;;
        zones)   cmd_cf_zones ${cf_rest[@]+"${cf_rest[@]}"} ;;
        *)       die "Usage: nanobk cf <connect|deploy|verify|install-admin-env|dns|zones> [args...]" ;;
      esac
      ;;
    vps)
      local vps_sub="${cmd_rest[0]:-}"
      local vps_rest=()
      if [[ ${#cmd_rest[@]} -gt 1 ]]; then
        vps_rest=("${cmd_rest[@]:1}")
      fi
      case "$vps_sub" in
        ip)
          local ip_sub="${vps_rest[0]:-}"
          local ip_rest=()
          if [[ ${#vps_rest[@]} -gt 1 ]]; then
            ip_rest=("${vps_rest[@]:1}")
          fi
          case "$ip_sub" in
            detect)  cmd_vps_ip_detect ${ip_rest[@]+"${ip_rest[@]}"} ;;
            *)       die "Usage: nanobk vps ip <detect> [args...]" ;;
          esac
          ;;
        *)       die "Usage: nanobk vps <ip> [args...]" ;;
      esac
      ;;
    setup)
      local setup_sub="${cmd_rest[0]:-}"
      local setup_rest=("${cmd_rest[@]:1}")
      case "$setup_sub" in
        dns)
          local dns_sub="${setup_rest[0]:-}"
          local dns_rest=("${setup_rest[@]:1}")
          if [[ "$dns_sub" == "apply" ]]; then
            cmd_setup_dns_apply ${dns_rest[@]+"${dns_rest[@]}"}
          else
            cmd_setup_dns ${setup_rest[@]+"${setup_rest[@]}"}
          fi
          ;;
        cert)
          local cert_sub="${setup_rest[0]:-}"
          local cert_rest=("${setup_rest[@]:1}")
          if [[ "$cert_sub" == "plan" ]]; then
            cmd_setup_cert_plan ${cert_rest[@]+"${cert_rest[@]}"}
          elif [[ "$cert_sub" == "issue" ]]; then
            cmd_setup_cert_issue ${cert_rest[@]+"${cert_rest[@]}"}
          else
            die "Usage: nanobk setup cert <plan|issue> [args...]"
          fi
          ;;
        flow|run) cmd_setup_flow ${setup_rest[@]+"${setup_rest[@]}"} ;;
        plan)     cmd_setup_plan ${setup_rest[@]+"${setup_rest[@]}"} ;;
        profile)  cmd_setup_profile ${setup_rest[@]+"${setup_rest[@]}"} ;;
        status)   cmd_home ${setup_rest[@]+"${setup_rest[@]}"} ;;
        token)
          local token_sub="${setup_rest[0]:-}"
          local token_rest=("${setup_rest[@]:1}")
          if [[ "$token_sub" == "rotate" ]]; then
            cmd_setup_token_rotate ${token_rest[@]+"${token_rest[@]}"}
          else
            die "Usage: nanobk setup token <rotate> [args...]"
          fi
          ;;
        wizard)   cmd_setup_wizard ${setup_rest[@]+"${setup_rest[@]}"} ;;
        production) cmd_setup_production ${setup_rest[@]+"${setup_rest[@]}"} ;;
        *)        die "Usage: nanobk setup <dns|cert|flow|plan|profile|production|run|status|token|wizard> [args...]" ;;
      esac
      ;;
    cert)
      local cert_sub="${cmd_rest[0]:-}"
      local cert_rest=()
      if [[ ${#cmd_rest[@]} -gt 1 ]]; then
        cert_rest=("${cmd_rest[@]:1}")
      fi
      case "$cert_sub" in
        plan)     cmd_setup_cert_plan ${cert_rest[@]+"${cert_rest[@]}"} ;;
        issue)    cmd_setup_cert_issue ${cert_rest[@]+"${cert_rest[@]}"} ;;
        *)        die "Usage: nanobk cert <plan|issue> [args...]" ;;
      esac
      ;;
    token)
      local token_sub="${cmd_rest[0]:-}"
      local token_rest=()
      if [[ ${#cmd_rest[@]} -gt 1 ]]; then
        token_rest=("${cmd_rest[@]:1}")
      fi
      case "$token_sub" in
        rotate)   cmd_setup_token_rotate ${token_rest[@]+"${token_rest[@]}"} ;;
        *)        die "Usage: nanobk token <rotate> [args...]" ;;
      esac
      ;;
    rotate)   cmd_rotate ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    export)   cmd_export ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    test)     cmd_test ${cmd_rest[@]+"${cmd_rest[@]}"} ;;
    version)  cmd_version ;;
    console)  cmd_console ;;
    "")       cmd_entry ;;
    *)        die "Unknown command: ${command}. Use --help for usage." ;;
  esac
}

main "$@"
