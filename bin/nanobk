            confirm_phrase="$2"
            args+=("$1" "$2"); shift 2 ;;
          --json)
            args+=("--json"); shift ;;
          --force|--overwrite|--apply|--yes|--keep-for-debug)
            die "cf dns owner-smoke-create: $1 is not allowed" ;;
          --help|-h)
