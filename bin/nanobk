#!/usr/bin/env bash
# NanoBK Proxy Suite — Unified CLI
#
# Stable command-line interface for NanoBK management.
# Designed for use by future Telegram Bot / Web Panel (1.x).
#
# Usage:
#   nanobk                    Interactive console (TTY) or entry help
#   nanobk console            Interactive console (explicit)
#   nanobk status
#   nanobk doctor
#   nanobk install --mode commands
#   nanobk cf deploy --dry-run
#   nanobk rotate all --skip-cloudflare
#   nanobk test
#   nanobk install-cli
#   nanobk version

set -Eeuo pipefail

# ── Version ─────────────────────────────────────────────────────────────────

NANOBK_VERSION="2.5.0"

# ── Colors ──────────────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

log()   { echo -e "${BLUE}[INFO]${NC}  $*"; }
ok()    { echo -e "${GREEN}[OK]${NC}    $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; }
err()   { echo -e "${RED}[ERROR]${NC} $*" >&2; }
die()   { err "$*"; exit 1; }

# ── Global flags ────────────────────────────────────────────────────────────

DRY_RUN=0
JSON_OUT=0
REPO_DIR=""
CONFIG_DIR="/etc/nanobk"

# ── JSON helpers ────────────────────────────────────────────────────────────

json_escape() {
  local input="$1"
  if command -v python3 &>/dev/null; then
    printf '%s' "$input" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()), end="")'
  else
    local result="$input"
    result="${result//\\/\\\\}"
    result="${result//\"/\\\"}"
    result="${result//$'\t'/\\t}"
    result="${result//$'\n'/\\n}"
    result="${result//$'\r'/\\r}"
    printf '"%s"' "$result"
  fi
}

# ── Fingerprint helper ──────────────────────────────────────────────────────

fingerprint_secret() {
  local value="$1"
  if [[ -z "$value" ]]; then
    echo ""
    return
  fi
  if command -v sha256sum &>/dev/null; then
    printf '%s' "$value" | sha256sum | awk '{print "sha256:" substr($1,1,8)}'
  elif command -v shasum &>/dev/null; then
    printf '%s' "$value" | LC_ALL=C LANG=C shasum -a 256 2>/dev/null | awk '{print "sha256:" substr($1,1,8)}'
  else
    echo "present"
  fi
}

# ── Safe env reader ─────────────────────────────────────────────────────────

# Read a single value from an env file without sourcing it.
# Does NOT execute shell commands in the file.
# Supports: KEY=value, KEY="value", KEY='value'
# Does NOT support: variable expansion ($OTHER), command substitution, multi-line.

read_env_value() {
  local file="$1"
  local key="$2"
  [[ -f "$file" ]] || return 0
  awk -v key="$key" '
    /^[[:space:]]*#/ { next }
    /^[[:space:]]*$/ { next }
    {
      line=$0
      sub(/^[[:space:]]*/, "", line)
      if (line ~ "^" key "=") {
        sub("^" key "=", "", line)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", line)
        # Strip surrounding quotes
        if ((substr(line,1,1) == "\"" && substr(line,length(line),1) == "\"") ||
            (substr(line,1,1) == "\x27" && substr(line,length(line),1) == "\x27")) {
          line=substr(line,2,length(line)-2)
        }
        print line
        exit
      }
    }
  ' "$file"
}

# ── Repo resolution ─────────────────────────────────────────────────────────

resolve_repo_dir() {
  # 1. Explicit --repo-dir already set
  if [[ -n "$REPO_DIR" ]]; then
    return
  fi

  # 2. Environment variable
  if [[ -n "${NANOBK_REPO_DIR:-}" ]]; then
    REPO_DIR="$NANOBK_REPO_DIR"
    return
  fi

  # 3. Script-local repository (highest auto-detect priority)
  #    When running ./some-clone/bin/nanobk, that clone should win.
  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -f "${script_dir}/../installer/install.sh" ]]; then
    REPO_DIR="$(cd "${script_dir}/.." && pwd)"
    return
  fi

  # 4. Config file
  local config_file="${CONFIG_DIR}/config.env"
  if [[ -f "$config_file" ]]; then
    local repo_from_config
    repo_from_config=$(grep -E '^NANOBK_REPO_DIR=' "$config_file" 2>/dev/null | head -1 | cut -d= -f2- | tr -d '"' || true)
    if [[ -n "$repo_from_config" ]] && [[ -d "$repo_from_config" ]]; then
      REPO_DIR="$repo_from_config"
      return
    fi
  fi

  # 5. Well-known paths
  for candidate in "/opt/NanoBK-Proxy-Suite" "${HOME}/NanoBK-Proxy-Suite"; do
    if [[ -d "$candidate" ]] && [[ -f "$candidate/installer/install.sh" ]]; then
      REPO_DIR="$candidate"
      return
    fi
  done

  die "无法定位 NanoBK 仓库。
请设置:
  export NANOBK_REPO_DIR=/path/to/NanoBK-Proxy-Suite
或重新运行 bootstrap:
  bash <(curl -fsSL https://raw.githubusercontent.com/kairkiss/NanoBK-Proxy-Suite/main/installer/bootstrap.sh)"
}

# ── Safe command runner ─────────────────────────────────────────────────────

print_cmd() {
  printf "  ${CYAN}\$${NC} "
  printf "%q " "$@"
  printf "\n"
}

run_script() {
  local desc="$1"
  shift
  local cmd=("$@")

  log "$desc"
  print_cmd "${cmd[@]}"

  if [[ "$DRY_RUN" == "1" ]]; then
    echo -e "  ${CYAN}[DRY-RUN]${NC} 跳过执行"
    return 0
  fi

  "${cmd[@]}"
}

# ── Commands ────────────────────────────────────────────────────────────────

cmd_version() {
  echo "nanobk ${NANOBK_VERSION}"
}

# ── CLI UI helpers ──────────────────────────────────────────────────────────

# Returns 0 if both stdin and stdout are TTYs.
# Test-only override: NANOBK_TEST_FORCE_TTY=1 bypasses TTY check.
is_interactive_tty() {
  [[ "${NANOBK_TEST_FORCE_TTY:-}" == "1" ]] && return 0
  [[ -t 0 ]] && [[ -t 1 ]]
}

# UI primitives — no external deps, no Python, no curses
ui_title() {
  echo -e "${BOLD}$*${NC}"
}

ui_section() {
  echo ""
  echo -e "  ${BOLD}$*${NC}"
}

ui_hint() {
  echo -e "  ${CYAN}$*${NC}"
}

ui_success() {
  echo -e "  ${GREEN}$*${NC}"
}

ui_warning() {
  echo -e "  ${YELLOW}$*${NC}"
}

ui_safe_action() {
  echo -e "  ${GREEN}[safe]${NC} $*"
}

ui_explicit_action() {
  echo -e "  ${YELLOW}[explicit]${NC} $*"
}

ui_advanced_action() {
  echo -e "  ${CYAN}[advanced]${NC} $*"
}

console_pause() {
  is_interactive_tty || return 0
  echo ""
  printf "  Press Enter to return to menu…"
  read -r _ || true
}

# ── Console helpers ─────────────────────────────────────────────────────────

print_console_header() {
  echo ""
  echo -e "${CYAN}${BOLD}"
  echo "  ╔╗ ╔═╗╔╗╔╔╦╗╔╗╔╔═╗╦  ╦╔═╗"
  echo "  ╠╩╗║╣ ║║║ ║║║║║╠═╣║  ║║ ║"
  echo "  ╚═╝╚═╝╝╚╝═╩╝╝╚╝╩ ╩╩═╝╩╚═╝"
  echo -e "${NC}"
  echo -e "  ${BOLD}NanoBK Proxy Suite${NC} v${NANOBK_VERSION}"
  echo ""
  echo -e "  ${CYAN}欢迎使用 NanoBK${NC}"
  echo "  让 VPS 代理部署变简单"
  echo ""
  echo "  Safe by default · 需要明确确认才会执行操作"
  echo ""
}

print_console_menu() {
  echo -e "  ${BOLD}主菜单${NC}"
  echo ""
  echo "  1) 开始配置 NanoBK"
  echo "  2) 查看当前状态"
  echo "  3) 诊断问题"
  echo "  4) 域名和 Cloudflare 设置"
  echo "  5) 安全与密钥"
  echo "  6) 导出订阅 / 节点"
  echo "  7) 安装或修复 CLI"
  echo "  8) 高级命令"
  echo "  9) 退出"
  echo ""
}

# DNS submenu — guidance-first, beginner-friendly
console_dns_submenu() {
  ui_section "域名和 Cloudflare 设置"
  ui_hint "我会先检查，不会直接改你的 DNS。"
  echo ""
  echo "  1) 连接 Cloudflare / 选择域名"
  echo "  2) 规划 proxy/web 子域名"
  echo "  3) 准备创建 DNS 记录"
  echo "  4) 证书自动化预检"
  echo "  5) 证书签发预案"
  echo "  6) 引导设置向导"
  echo "  7) DNS 设置助手"
  echo "  8) 检测 VPS IP"
  echo "  9) 检查域名可用性"
  echo " 10) 生成 DNS 计划"
  echo " 11) 预检摘要"
  echo " 12) 保存设置配置"
  echo " 13) 查看设置配置"
  echo " 14) 清除设置配置"
  echo " 15) 返回"
  echo ""
  local choice
  read -rp "  选择 [1-15]: " choice || { echo ""; return; }
  case "$choice" in
    1)
      echo ""
      ui_safe_action "连接 Cloudflare（只读验证，不会创建 DNS）:"
      echo ""
      cmd_cf_connect || true
      console_pause
      ;;
    2)
      echo ""
      ui_safe_action "规划 proxy/web 子域名（只读，不会创建 DNS）:"
      echo "  我只会检查和规划，不会创建 DNS。"
      echo ""
      cmd_setup_plan || true
      console_pause
      ;;
    3)
      echo ""
      ui_safe_action "准备创建 DNS 记录:"
      echo "  我会先生成创建预案。"
      echo "  真正创建 DNS 需要你复制命令并输入确认短语。"
      echo ""
      cmd_setup_dns_apply || true
      console_pause
      ;;
    4)
      echo ""
      ui_safe_action "证书自动化预检（只读，不会申请证书）:"
      echo "  我只会检查证书申请条件。"
      echo "  本步骤不会申请证书，不会修改服务配置。"
      echo ""
      cmd_setup_cert_plan || true
      console_pause
      ;;
    5)
      echo ""
      ui_safe_action "证书签发预案（只读，不会申请证书）:"
      echo "  我会生成证书签发预案。"
      echo "  真正申请证书需要你复制命令并输入确认短语。"
      echo ""
      cmd_setup_cert_issue || true
      console_pause
      ;;
    6)
      echo ""
      ui_safe_action "引导设置向导（只读，不会修改 DNS）:"
      echo ""
      cmd_setup_wizard || true
      console_pause
      ;;
    7)
      echo ""
      ui_safe_action "DNS 设置助手（只读，不会修改 DNS）:"
      echo ""
      echo "    nanobk setup dns --zone your-domain.com --api-env /path/to/cloudflare.env"
      echo ""
      echo "  自动检测 IP、检查可用性、生成 DNS 计划。"
      echo "  不会修改 DNS，不会修改 Cloudflare。"
      console_pause
      ;;
    8)
      echo ""
      ui_safe_action "检测 VPS 公网 IP（只读）:"
      echo ""
      cmd_vps_ip_detect || true
      console_pause
      ;;
    9)
      echo ""
      ui_safe_action "检查子域名可用性（只读）:"
      echo ""
      echo "    nanobk cf dns availability summary --zone your-domain.com --api-env /path/to/cloudflare.env"
      echo ""
      echo "  检查 proxy 和 web 子域名是否已被占用。"
      console_pause
      ;;
    10)
      echo ""
      ui_safe_action "生成 DNS 计划（只读，不会修改 DNS）:"
      echo ""
      echo "    nanobk cf dns plan-generator --zone your-domain.com --api-env /path/to/cloudflare.env"
      echo ""
      echo "  结合 IP 检测和可用性检查，生成 DNS 配置计划。"
      console_pause
      ;;
    11)
      echo ""
      ui_safe_action "预检摘要（只读，不会创建记录）:"
      echo ""
      echo "    nanobk cf dns create-preflight --zone your-domain.com --api-env /path/to/cloudflare.env"
      echo ""
      echo "  显示将会创建什么，但不会实际创建。"
      console_pause
      ;;
    12)
      echo ""
      ui_safe_action "保存设置配置（本地存储，不上传）:"
      echo ""
      echo "    nanobk setup profile save --zone your-domain.com --api-env /path/to/cloudflare.env"
      echo ""
      echo "  保存你的 DNS 设置，下次运行 setup dns 时不用重新输入。"
      console_pause
      ;;
    13)
      echo ""
      ui_safe_action "查看已保存的设置配置（脱敏显示）:"
      echo ""
      cmd_setup_profile show || true
      console_pause
      ;;
    14)
      echo ""
      ui_safe_action "清除设置配置:"
      echo ""
      echo "    nanobk setup profile clear"
      echo ""
      echo "  删除已保存的 DNS 设置配置。"
      console_pause
      ;;
    15|"")
      return
      ;;
    *)
      echo "  无效输入，请选择 1-15。"
      console_pause
      ;;
  esac
}

