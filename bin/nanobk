            echo "  No production DNS mutation. No overwrite. No force."
            return 0 ;;
          --dry-run)
            echo -e "  ${CYAN}[DRY-RUN]${NC} cf dns owner-smoke-create command prepared"
            echo "  api-env: <redacted>"
            echo "  No DNS mutation will be performed."
            return 0 ;;
