                [[ $# -ge 2 ]] || die "cf dns availability summary: --zone needs a value"
                args+=("$1" "$2"); shift 2 ;;
              --api-env)
                [[ $# -ge 2 ]] || die "cf dns availability summary: --api-env needs a path"
                args+=("$1" "$2"); shift 2 ;;
