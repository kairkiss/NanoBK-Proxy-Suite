                return 0 ;;
              *)
                die "cf dns profile preview: unknown option: $1"
                ;;
            esac
          done
          # Respect global --dry-run (sanitized)
          if [[ "$DRY_RUN" == "1" ]]; then
            echo -e "  ${CYAN}[DRY-RUN]${NC} nanobk cf dns profile preview would run; raw zone and IP arguments are hidden"
            return 0
          fi
          "${args[@]}"
          ;;
        generate)
