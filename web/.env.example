# NanoBK Web Panel — Environment Variables
# Copy this file to .env and fill in your values.
# Do NOT commit .env to Git.

# Web login token.
# Change this to a long random string.
NANOBK_WEB_TOKEN=change-me-long-random-token

# Bind address. Keep 127.0.0.1 unless you know what you are doing.
NANOBK_WEB_HOST=127.0.0.1

# Port.
NANOBK_WEB_PORT=8080

# Path to nanobk CLI.
NANOBK_CLI=/usr/local/bin/nanobk

# Optional repo dir passed to nanobk --repo-dir.
NANOBK_REPO_DIR=

# Command timeout seconds.
NANOBK_COMMAND_TIMEOUT=120

# Rotate command timeout seconds.
NANOBK_ROTATE_TIMEOUT=300

# true = rotate buttons show command but do not execute.
NANOBK_WEB_DRY_RUN=true

# Flask secret key for session cookies.
# Change in production.
NANOBK_WEB_SECRET_KEY=change-me-session-secret
