# NanoBK Telegram Bot — Environment Variables
# Copy this file to .env and fill in your values.
# Do NOT commit .env to Git.

# Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:REPLACE_ME

# Only this Telegram numeric user ID can use the bot.
# To find your ID: send /start to @userinfobot on Telegram.
OWNER_TELEGRAM_ID=123456789

# Path to nanobk CLI.
# Prefer installed CLI: /usr/local/bin/nanobk
# Or repo CLI: /path/to/NanoBK-Proxy-Suite/bin/nanobk
NANOBK_CLI=/usr/local/bin/nanobk

# Optional: repo dir passed to nanobk --repo-dir when needed.
# Leave empty if nanobk can auto-locate the repo.
NANOBK_REPO_DIR=

# Command timeout seconds.
NANOBK_COMMAND_TIMEOUT=120

# Rotate command timeout seconds.
NANOBK_ROTATE_TIMEOUT=300

# Dry run mode for development/testing.
# true = Bot prints rotate commands but does not execute them.
# /status and /doctor still execute normally.
NANOBK_BOT_DRY_RUN=false
