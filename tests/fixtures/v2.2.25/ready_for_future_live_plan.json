{
  "repo_gate": {
    "clean": true,
    "expected_head": true,
    "no_release_tag": true,
    "no_public_integration": true
  },
  "placeholder_validator_gate": {
    "status": "ready_for_future_owner_approved_live_plan",
    "actual_live_test_allowed": "no",
    "public_apply_allowed": "no",
    "real_env_read": "no",
    "real_dns_mutation_performed": "no"
  },
  "credential_reference_gate": {
    "reference_input_only": true,
    "reference_printed": false,
    "chmod_600_required": true,
    "cat_source_eval_forbidden": true,
    "token_echo_forbidden": true,
    "raw_api_output_forbidden": true
  },
  "record_identity_gate": {
    "one_record_only": true,
    "disposable_test_record_only": true,
    "create_only_first": true,
    "dns_only": true,
    "no_delete": true,
    "no_overwrite": true,
    "no_production_names": true,
    "no_service_hostnames": true,
    "same_name_cname_absent": true
  },
  "precheck_gate": {
    "available": true,
    "placeholder_complete": true,
    "safe_record_category": true,
    "absent_or_managed_test_only": true,
    "same_name_cname_absent": true,
    "no_unmanaged_overwrite": true,
    "no_delete": true
  },
  "preview_gate": {
    "generated": true,
    "safe_only": true,
    "redaction_passed": true,
    "raw_mutation_command_shown": false
  },
  "approval_gate": {
    "exact_phrase_matched": true,
    "after_preview": true,
    "after_rollback": true,
    "after_postcheck_explanation": true,
    "before_mutation": true
  },
  "fake_helper_capture_gate": {
    "fake_transport_only": true,
    "real_helper_called": false,
    "stdout_captured": true,
    "stderr_captured": true,
    "raw_output_printed": false,
    "returncode": 0
  },
  "fake_helper_json_gate": {
    "parse_ok": true,
    "schema_ok": true,
    "allowed_fields_only": true,
    "raw_fields_removed": true
  },
  "fake_postcheck_gate": {
    "fake_postcheck_only": true,
    "record_exists": true,
    "type_matches": true,
    "content_matches_internally": true,
    "proxied_false": true,
    "same_name_cname_absent": true,
    "no_unexpected_delete": true,
    "verified_only_after_postcheck": true
  },
  "classifier_gate": {
    "status": "ready_for_future_owner_approved_live_plan",
    "ambiguous": false
  },
  "safe_renderer_gate": {
    "safe_summary_generated": true,
    "fake_live_honesty": true,
    "raw_values_removed": true
  },
  "redaction_gate": {
    "passed": true,
    "secret_or_address_printed": false,
    "raw_command_printed": false,
    "raw_api_printed": false
  },
  "public_ux_gate": {
    "bin_integration": false,
    "bot_apply": false,
    "web_apply": false,
    "installer_apply": false,
    "tag_release": false
  }
}