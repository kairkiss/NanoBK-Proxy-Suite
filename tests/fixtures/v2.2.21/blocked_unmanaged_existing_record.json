{
  "repo": {"clean": true, "head_expected": true},
  "scope": {
    "disposable_test_record": true,
    "owner_controlled_zone": true,
    "single_record": true,
    "single_record_type_first": true,
    "create_only_first": true,
    "no_production_hostname": true,
    "no_delete": true,
    "no_unmanaged_overwrite": true,
    "no_public_ux": true
  },
  "approval": {
    "phrase_present": true,
    "exact_phrase_matched": true,
    "shown_safe_identity": true,
    "shown_planned_action_category": true,
    "shown_no_delete_policy": true,
    "shown_manual_rollback": true,
    "shown_postcheck_requirement": true,
    "shown_redacted_output_policy": true
  },
  "credentials": {
    "permission_600": true,
    "env_path_printed": false,
    "token_printed": false,
    "cat_source_eval_used": false
  },
  "precheck": {
    "absent_or_managed_test_only": true,
    "same_name_cname_absent": true,
    "record_type_expected": true,
    "no_unmanaged_existing_record": false,
    "preview_generated": true,
    "owner_approval_after_preview": true
  },
  "mutation_gate": {
    "actual_live_mutation_blocked_in_this_version": true,
    "future_create_only": true,
    "future_single_record": true,
    "future_no_delete": true,
    "future_no_overwrite": true,
    "future_stop_on_first_failure": true,
    "future_raw_output_captured": true,
    "future_safe_summary_only": true
  },
  "postcheck": {
    "planned": true,
    "api_acceptance_required": true,
    "get_observes_record_required": true,
    "record_exists_required": true,
    "type_matches_required": true,
    "content_matches_internally_required": true,
    "proxied_false_required": true,
    "no_cname_conflict_required": true,
    "count_matches_required": true,
    "no_unexpected_delete_required": true,
    "verified_only_after_postcheck": true
  },
  "rollback": {
    "manual_instruction_exists": true,
    "automatic_delete_disabled": true,
    "manual_dashboard_revert_required": true,
    "no_blind_retry": true
  },
  "redaction": {
    "scan_before_output": true,
    "safe_summary_only": true,
    "raw_mutation_command_printed": false,
    "raw_api_printed": false,
    "secret_or_address_printed": false
  },
  "public_ux": {
    "bin_integration": false,
    "bot_apply": false,
    "web_apply": false,
    "installer_apply": false,
    "separate_review_required": true
  }
}
